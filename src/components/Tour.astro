---
// El tour del onboarding (P0, segunda parte): recorrido guiado por TODA la plataforma,
// con la anatomia de Aurea (UpGrade): un FOCO que recorta la pieza destacada del velo
// oscuro (box-shadow de 200vmax), una TARJETA con la voz de Nara que se desliza junto al
// foco (hoja inferior fija en movil), y un BLOQUEO que congela la pagina mientras dura.
//
// El estado (indice del paso) vive en sessionStorage y cruza paginas: cada pagina monta
// este componente, lee el indice y, si el paso es de otra sala, navega hasta ella. Si un
// selector no existe o esta oculto por estado, la parada se salta sola.
//
// La regla de oro (aprendida en Aurea): ACERCAR (scroll, una vez al entrar en el paso) y
// SEGUIR (recolocar el foco por frame si el layout se mueve) van SEPARADOS. Mezclarlos
// realimenta el scroll y el foco tiembla. Y durante el recorrido la fortaleza se queda
// quieta (html.tour-quieto): sin eso, las entradas mueven la pieza bajo el foco.
---

<div class="tour" id="tour-capa" hidden>
  <!-- Durante el recorrido la pagina no se toca: un clic en el HUD navegaria a otra
       sala y el tour volveria a traerte, que despista mas que ayuda. -->
  <div class="tour__bloqueo" aria-hidden="true"></div>
  <div class="tour__foco" id="tour-foco" aria-hidden="true"></div>
  <div class="tour__caja" id="tour-caja" role="dialog" aria-modal="true" aria-label="Recorrido de bienvenida">
    <div class="tour__cab">
      <span class="tour__orbe" aria-hidden="true"><img src="/assets/retratos/ui/nara.webp" alt="" width="256" height="256" /></span>
      <span class="tour__quien">Nara</span>
      <span class="tour__paso" id="tour-paso"></span>
    </div>
    <h3 class="tour__t" id="tour-titulo"></h3>
    <p class="tour__txt" id="tour-texto"></p>
    <div class="tour__acc">
      <button class="tour__salir" type="button" id="tour-salir">Saltar el recorrido</button>
      <button class="btn-linea tour__sig" type="button" id="tour-sig" data-augmented-ui="l-clip-y r-clip-y">Siguiente</button>
    </div>
  </div>
</div>

<script>
  type Paso = { pagina: string; sel: string; t: string; x: string };

  // Los pasos, por toda la plataforma. Cada uno enfoca UNA pieza real de su sala; el del
  // Mapa apunta a la chincheta CENTRAL del castro (Sala de Mandos), como el Telar en Aurea:
  // en movil el lienzo se recorta a lo ancho y una de los bordes quedaria fuera de pantalla.
  const PASOS: Paso[] = [
    { pagina: '/dashboard', sel: '.cab', t: 'Bienvenida a tu fortaleza', x: 'Soy Nara, tu guardiana. En un minuto te enseño toda tu fortaleza. Puedes saltarte el recorrido cuando quieras.' },
    { pagina: '/dashboard', sel: '.m-activa-caja', t: 'La intervención del mes', x: 'Esto es lo que toca hoy: una grieta que reparar. Cada mes se abre una, y repararla fortalece tu despacho.' },
    { pagina: '/dashboard', sel: '.pasos', t: 'Tu recorrido del mes', x: 'Ves la clase en la Biblioteca, aplicas el reto en la Torre, y la recompensa se enciende sola.' },
    { pagina: '/dashboard', sel: '.m-ficha', t: 'Tu avance', x: 'Reparando grietas subes de rango y enciendes la fortaleza. Aquí ves por dónde vas y lo que ya has ganado.' },
    { pagina: '/mapa', sel: '.hito[data-slug="sala-mandos"]', t: 'El Mapa: tu viaje', x: 'Las doce intervenciones sobre el castro, en tres sendas. El mapa entero de tu primer ciclo: dónde estás y lo que falta.' },
    { pagina: '/biblioteca', sel: '.destacado', t: 'La Biblioteca de Recursos', x: 'El catálogo del club: la clase de cada mes con su recurso. Aquí ves el contenido; el reto se hace en la Torre.' },
    { pagina: '/torre-retos', sel: '.destacado', t: 'La Torre de Retos', x: 'Donde aplicas lo aprendido. Un reto por intervención: cada uno enciende un tramo de la Torre.' },
    { pagina: '/sala-mandos', sel: '.planos', t: 'La Sala de Mandos', x: 'Los cuatro pilares de tu despacho: precios, servicios, organización y planificación. Aquí ves cuáles están firmes.' },
    { pagina: '/consejo', sel: '.consejo__altar', t: 'El Consejo', x: 'La sala de consulta a Conchi. Traes una duda de tu despacho y se te responde con criterio, no con juicio.' },
    { pagina: '/mirador', sel: '.composer', t: 'El Mirador de la Fortaleza', x: 'La comunidad: otras fortalezas, no un foro. Aquí compartes avances y bloqueos, y das señales a los demás.' },
    { pagina: '/asesor', sel: '.yo', t: 'El asesor: quién eres', x: 'Tu perfil dentro de la fortaleza: tu rango, tu arquetipo y las insignias que vas forjando. Cuelga de tu avatar, arriba a la derecha.' },
    { pagina: '/recompensas', sel: '.saldo', t: 'Las Recompensas', x: 'Lo que la fortaleza te devuelve al avanzar. No es una tienda: cada recompensa se abre sola al cruzar su umbral, no se compra nada.' },
    { pagina: '/dashboard', sel: '.paso--toca', t: 'La fortaleza es tuya', x: 'Ya la conoces entera. Empieza cuando quieras: enciende la primera señal. Estaré por aquí para guiarte.' },
  ];

  const KEY = 'fortaleza-tour-i';
  // El espejo en memoria respalda al almacen: con sessionStorage capado (Safari con
  // cookies bloqueadas, webviews) leer() no puede devolver null para siempre o el boton
  // de Siguiente queda muerto. Con el espejo, el avance dentro de la pagina funciona;
  // sin almacen no hay cruce de paginas posible, pero el tour no se queda colgado.
  let memoria: number | null = null;
  const leer = () => { try { const v = sessionStorage.getItem(KEY); return v === null ? null : Number(v); } catch { return memoria; } };
  const escribir = (v: number | null) => { memoria = v; try { v === null ? sessionStorage.removeItem(KEY) : sessionStorage.setItem(KEY, String(v)); } catch {} };
  const ruta = (p: string) => p.replace(/\/$/, '') || '/';

  const capa = document.getElementById('tour-capa') as HTMLElement;
  const foco = document.getElementById('tour-foco') as HTMLElement;
  const caja = document.getElementById('tour-caja') as HTMLElement;
  const elSig = document.getElementById('tour-sig') as HTMLElement;

  // La GENERACION invalida todo lo diferido del paso anterior (reintentos, bucle de
  // seguimiento, la espera inicial): sin ella, los timers del paso viejo seguian vivos
  // al avanzar y peleaban el scroll con el paso nuevo (tirones de media pantalla).
  let gen = 0;
  // Y la guarda de navegacion mata el doble clic en Siguiente al cruzar de sala: el
  // boton sigue vivo hasta el unload y cada clic extra se saltaba una parada.
  let navegando = false;

  // Debe coincidir con la media query de la hoja de abajo: si el CSS pasa a hoja a 860
  // y el JS decide "movil" con otro numero, hay una franja donde la tarjeta es hoja pero
  // se coloca como flotante (o al reves) y queda descolocada.
  const esMovil = () => innerWidth <= 860 || innerHeight <= 480;

  // ── ACERCAR: llevar la pieza a la vista. Una vez por paso, nunca en el bucle. ──

  // El scroll no siempre es el de la ventana: en las salas a pantalla completa scrollea
  // una caja interior con overflow:auto (la escalera de la Torre, el catalogo de la
  // Biblioteca). Hay que mover ESA; window.scrollBy no las toca.
  function contenedor(el: Element): Element | null {
    let p = el.parentElement;
    while (p) {
      const cs = getComputedStyle(p);
      if (/(auto|scroll)/.test(cs.overflowY) && p.scrollHeight > p.clientHeight + 4) return p;
      if (p === document.body) return null;
      p = p.parentElement;
    }
    return null;
  }
  function desplaza(el: Element, dy: number) {
    if (Math.abs(dy) < 2) return;
    const c = contenedor(el);
    if (c) c.scrollBy({ top: dy, behavior: 'instant' as ScrollBehavior });
    else window.scrollBy({ top: dy, behavior: 'instant' as ScrollBehavior });
  }
  function acerca(el: Element) {
    const M = 24;
    if (esMovil()) {
      // La hoja inferior tapa la parte baja: la pieza se centra en la franja LIBRE.
      const zona = innerHeight - (caja.offsetHeight || 200);
      const r0 = el.getBoundingClientRect();
      const alto = Math.min(r0.height, zona - M * 2);
      const desvio = (r0.top + alto / 2) - zona / 2;
      if (Math.abs(desvio) > 30) desplaza(el, desvio);
      return;
    }
    const r0 = el.getBoundingClientRect();
    if (r0.top >= 70 && r0.bottom <= innerHeight - 70) return; // ya se ve entera
    el.scrollIntoView({ block: 'center', inline: 'center', behavior: 'instant' as ScrollBehavior });
    const r1 = el.getBoundingClientRect();
    if (r1.height > innerHeight - M * 2) {
      // mas alta que la pantalla (la ficha del asesor en corto): se enseña su comienzo
      if (r1.top < M || r1.top > innerHeight * 0.35) desplaza(el, r1.top - M);
    } else if (r1.top < M) desplaza(el, r1.top - M);
    else if (r1.bottom > innerHeight - M) desplaza(el, r1.bottom - innerHeight + M);
  }

  // ── COLOCAR: pintar el foco sobre la pieza y la tarjeta junto a el. ──
  function coloca(el: Element) {
    const movil = esMovil();
    const r = el.getBoundingClientRect();
    const M = 8;
    // El recorte nunca se sale de la pantalla: hay piezas mas altas que el viewport y
    // otras que viven en el lienzo del Mapa (con arrastre y zoom).
    const L = Math.max(4, r.left - M), T = Math.max(4, r.top - M);
    // En movil tampoco se mete por debajo de la hoja: se recorta contra ella y el marco
    // se ve entero aunque la pieza siga por debajo.
    const suelo = movil ? Math.min(innerHeight - 4, caja.getBoundingClientRect().top - 8) : innerHeight - 4;
    const Rt = Math.min(innerWidth - 4, r.right + M), B = Math.min(suelo, r.bottom + M);
    foco.style.left = `${L}px`; foco.style.top = `${T}px`;
    foco.style.width = `${Math.max(0, Rt - L)}px`; foco.style.height = `${Math.max(0, B - T)}px`;
    if (movil) return; // la hoja va fija abajo por CSS

    // Escritorio: la tarjeta debajo del foco; si no cabe, encima; si tampoco, centrada.
    const cw = caja.offsetWidth || 360, ch = caja.offsetHeight || 190;
    let x = L + (Rt - L) / 2 - cw / 2;
    x = Math.max(16, Math.min(x, innerWidth - cw - 16));
    let y = B + 18;
    if (y + ch > innerHeight - 16) y = T - ch - 18;
    if (y < 16) y = Math.max(16, innerHeight / 2 - ch / 2);
    caja.style.left = `${x}px`; caja.style.top = `${y}px`;
  }

  // ── SEGUIR: el bucle solo RECOLOCA (nunca scrollea) y solo si el rect cambio. ──
  let rafId = 0;
  function sigue(sel: string, g: number) {
    cancelAnimationFrame(rafId);
    let ultima = '';
    (function paso() {
      if (g !== gen || capa.hasAttribute('hidden')) return;
      const el = document.querySelector(sel);
      if (el) {
        const r = el.getBoundingClientRect();
        const firma = `${r.left | 0},${r.top | 0},${r.width | 0}`;
        if (firma !== ultima) { ultima = firma; coloca(el); }
      }
      rafId = requestAnimationFrame(paso);
    })();
  }

  function muestra(i: number) {
    const paso = PASOS[i];
    if (!paso) { fin(); return; }
    if (paso.pagina !== ruta(location.pathname)) {
      if (!navegando) { navegando = true; location.href = paso.pagina; }
      return;
    }
    const el = document.querySelector(paso.sel);
    // Sin pieza (o oculta por estado, como los pasos del Patio en la fortaleza
    // completada): la parada se salta sola.
    if (!el || el.getClientRects().length === 0) { escribir(i + 1); muestra(i + 1); return; }
    const g = ++gen;
    (document.getElementById('tour-paso') as HTMLElement).textContent = `${i + 1} / ${PASOS.length}`;
    (document.getElementById('tour-titulo') as HTMLElement).textContent = paso.t;
    (document.getElementById('tour-texto') as HTMLElement).textContent = paso.x;
    elSig.textContent = i === PASOS.length - 1 ? 'Empezar' : 'Siguiente';
    capa.classList.remove('tour--espera');
    capa.removeAttribute('hidden');
    // La fortaleza se queda quieta: sin entradas ni transiciones moviendose bajo el foco.
    document.documentElement.classList.add('tour-quieto');
    // El teclado vive en la tarjeta: el dialogo recibe el foco en su accion principal.
    elSig.focus({ preventScroll: true });
    // Las entradas siguen asentando el layout un rato: se reintenta el acercamiento
    // mientras cuaja. No puede ir en el bucle de seguir o el scroll se realimenta, y
    // muere con la generacion: los reintentos de un paso viejo no pelean con el nuevo.
    requestAnimationFrame(() => { if (g === gen) { acerca(el); coloca(el); } });
    [200, 500, 900].forEach((t) => setTimeout(() => {
      if (g !== gen || capa.hasAttribute('hidden')) return;
      const e2 = document.querySelector(paso.sel);
      if (e2) { acerca(e2); coloca(e2); }
    }, t));
    sigue(paso.sel, g);
  }

  // La espera: bloqueo TEMPRANO mientras la sala asienta (700ms) antes de pintar el
  // paso. Sin el, un clic rapido navegaba en plena espera y el tour reaparecia luego
  // descolocado en otra sala.
  function espera(i: number) {
    capa.classList.add('tour--espera');
    capa.removeAttribute('hidden');
    const g = gen;
    setTimeout(() => { if (g === gen) muestra(i); }, 700);
  }

  function fin() {
    gen++;
    escribir(null);
    capa.setAttribute('hidden', '');
    capa.classList.remove('tour--espera');
    document.documentElement.classList.remove('tour-quieto');
    cancelAnimationFrame(rafId);
  }

  elSig.addEventListener('click', () => {
    if (navegando) return;
    const i = leer(); if (i === null) return;
    const sig = i + 1;
    if (sig >= PASOS.length) { fin(); return; }
    escribir(sig);
    if (PASOS[sig].pagina === ruta(location.pathname)) muestra(sig);
    else { navegando = true; location.href = PASOS[sig].pagina; }
  });
  document.getElementById('tour-salir')?.addEventListener('click', fin);
  addEventListener('keydown', (e) => { if (!capa.hasAttribute('hidden') && e.key === 'Escape') fin(); });

  // El foco de teclado no se escapa de la tarjeta: el bloqueo come punteros pero no el
  // orden de tabulacion, y sin esto Tab llegaba al HUD (y al enlace de saltar, z-200).
  addEventListener('focusin', (e) => {
    if (capa.hasAttribute('hidden') || capa.classList.contains('tour--espera')) return;
    if (!caja.contains(e.target as Node)) elSig.focus({ preventScroll: true });
  });

  // Al cambiar la ventana se RE-ACERCA ademas de recolocar: rotar el movil (o cruzar el
  // umbral de la hoja) puede dejar la pieza bajo la hoja y el foco recortado a nada.
  addEventListener('resize', () => {
    const i = leer();
    if (i !== null && !capa.hasAttribute('hidden') && !capa.classList.contains('tour--espera')) {
      const el = document.querySelector(PASOS[i]?.sel);
      if (el) { acerca(el); coloca(el); }
    }
  });

  // El boton atras saca la pagina de la bfcache TAL CUAL se dejo: congelada por el
  // tour (velo echado, bloqueo comiendose los clics, paso viejo pintado). Se descongela
  // y, si el recorrido sigue vivo en el almacen, se retoma en su paso REAL.
  addEventListener('pageshow', (e) => {
    if (!(e as PageTransitionEvent).persisted) return;
    navegando = false;
    gen++;
    cancelAnimationFrame(rafId);
    capa.setAttribute('hidden', '');
    capa.classList.remove('tour--espera');
    document.documentElement.classList.remove('tour-quieto');
    const i = leer();
    if (i !== null) espera(i);
  });

  // Arranque (?tour desde la entrega) o RESUME al llegar a la pagina del paso actual.
  const params = new URLSearchParams(location.search);
  if (params.has('tour')) {
    history.replaceState(null, '', location.pathname);
    escribir(0);
    espera(0);
  } else {
    const actual = leer();
    if (actual !== null) espera(actual);
  }
</script>

<style is:global>
  .tour[hidden] { display: none; }

  /* El bloqueo se come los clics de TODO lo demas: el HUD y sus paneles (contexto del
     shell, z-50), la barra inferior (55), el conmutador (70) y la hoja de Mas (78). */
  .tour__bloqueo { position: fixed; inset: 0; z-index: 79; }

  /* La espera: la capa esta puesta (el bloqueo ya come clics) pero el foco y la tarjeta
     aun no se pintan, mientras la entrada de la sala asienta. */
  .tour--espera .tour__foco, .tour--espera .tour__caja { visibility: hidden; }

  /* ── La fortaleza se queda QUIETA durante el recorrido ──
     Con las entradas en marcha, la pieza seguia moviendose bajo el foco y el coach mark
     parecia desalineado. Se matan animation y transition (NUNCA transform: muchas piezas
     lo usan para COLOCARSE, no para entrar; anularlo las descoloca). El velo queda fuera
     del apagon a proposito: ver abajo. */
  html.tour-quieto *:not(.tour__foco):not(.tour__caja):not(.tour__caja *):not(.velo):not(.velo *) {
    animation: none !important;
    transition: none !important;
  }
  /* El Patio esconde su base hasta la entrada (.entra + destape): sin animacion nunca
     llegaria a verse. Se fuerza el estado "ya entrado". */
  html.tour-quieto .cab,
  html.tour-quieto .m-activa-caja,
  html.tour-quieto .m-ficha { opacity: 1 !important; }
  /* El velo del cruce, INVISIBLE pero vivo: con display:none su animacion de llegada se
     reiniciaba al cerrar el tour y metia un fogonazo negro a pantalla completa. Con
     visibility corre invisible, termina, y al soltar el velo ya esta transparente. */
  html.tour-quieto .velo { visibility: hidden !important; pointer-events: none !important; }

  /* EL FOCO: recorta la pieza del velo oscuro con la sombra de 200vmax y se desliza
     de una pieza a la siguiente. Luz cian: es la luz de Nara, como toda la guia. */
  .tour__foco {
    position: fixed; z-index: 80; pointer-events: none; border-radius: 8px;
    box-shadow:
      0 0 0 2px rgba(95, 208, 224, 0.75),
      0 0 34px rgba(95, 208, 224, 0.35),
      0 0 0 200vmax rgba(6, 9, 14, 0.8);
    transition: all 0.45s cubic-bezier(0.22, 0.8, 0.3, 1);
  }

  /* LA TARJETA: la voz de Nara. Flota junto al foco y viaja con el. */
  .tour__caja {
    position: fixed; z-index: 81; width: min(360px, calc(100vw - 32px));
    padding: clamp(16px, 2vw, 22px);
    background: linear-gradient(160deg, rgba(22, 34, 48, 0.98), rgba(9, 13, 20, 0.98));
    box-shadow: inset 0 0 0 1px rgba(95, 208, 224, 0.3), 0 20px 50px rgba(0, 0, 0, 0.6);
    border-radius: 10px;
    transition: all 0.45s cubic-bezier(0.22, 0.8, 0.3, 1);
  }

  .tour__cab { display: flex; align-items: center; gap: 10px; margin-bottom: 12px; }
  .tour__orbe { width: 34px; height: 34px; border-radius: 50%; overflow: hidden; flex: none; box-shadow: inset 0 0 0 1px rgba(95, 208, 224, 0.5), 0 0 14px rgba(63, 169, 201, 0.3); }
  .tour__orbe img { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .tour__quien { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; color: var(--aqua); flex: 1; }
  .tour__paso { font-size: 0.72rem; color: var(--mist); }

  .tour__t { margin: 0; font-family: var(--serif, serif); font-size: 1.12rem; color: var(--bone); }
  .tour__txt { margin: 7px 0 0; font-size: 0.9rem; line-height: 1.55; color: var(--moon); }

  .tour__acc { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: clamp(14px, 2vh, 18px); }
  .tour__salir { padding: 0; font: inherit; font-size: 0.76rem; color: var(--mist); background: none; border: 0; cursor: pointer; }
  .tour__salir:hover { color: var(--moon); }
  .tour__sig { padding: 9px 20px; font-size: 0.8rem; }

  /* MOVIL Y APAISADO: la tarjeta es una HOJA inferior fija, nada de recolocarla junto
     al foco (no hay sitio). El mismo umbral que decide esMovil() en el script. */
  @media (max-width: 860px), (max-height: 480px) {
    .tour__caja {
      left: 0 !important; right: 0; bottom: 0; top: auto !important;
      width: auto; border-radius: 10px 10px 0 0;
      padding: 16px 18px calc(16px + env(safe-area-inset-bottom, 0px));
      box-shadow: inset 0 1px 0 rgba(95, 208, 224, 0.3), 0 -22px 50px rgba(0, 0, 0, 0.6);
    }
    /* Hueco para que lo ultimo de cada sala pueda subir por encima de la hoja: sin esto
       el foco del ultimo paso se queda debajo y no hay scroll que lo suba. El colchon
       se retira con transicion al cerrar: quitarlo de golpe recortaba el scroll y el
       contenido brincaba (247px medidos en el paso de Tu avance). */
    html.tour-quieto body { padding-bottom: calc(300px + env(safe-area-inset-bottom, 0px)) !important; }
    body { transition: padding-bottom 0.35s ease; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tour__foco, .tour__caja, body { transition: none; }
  }
</style>
