---
// Login (Puerta de la Fortaleza). Primera pantalla del prototipo.
// Solo estetica: los campos no envian nada y el boton lleva al Dashboard.
// Mas adelante, al terminar el acceso, disparara el Onboarding.
// Va sin el shell de Fortaleza.astro (aqui no hay navegacion todavia).
import '../styles/tokens.css';
import Velo from '../components/Velo.astro';

const POSTER = '/assets/mapa-escenas/ui/patio-entrada.webp';
const VIDEO = '/assets/animaciones/patio-entrada.webm';

// Los campos son el mecanismo de la puerta: ranuras chaflanadas con su filo, el mismo
// lenguaje que las ranuras del Patio. Eran lo unico del producto que seguia siendo
// un formulario web (una raya de 1px). Ver docs/DESIGN.md.
const RANURA = 'tl-clip br-clip border';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Club de la Asesoría</title>
    <meta name="description" content="Acceso al Club de la Asesoría." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- El poster es la escena entera: que llegue el primero -->
    <link rel="preload" as="image" href={POSTER} fetchpriority="high" />
    <!-- La cara del enlace cuando se comparte -->
    <meta name="theme-color" content="#090D14" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="La Fortaleza del Asesor, Club de la Asesoría" />
    <meta property="og:description" content="Tu despacho es una fortaleza. Nara ya ha encontrado la primera grieta." />
    <meta property="og:image" content="https://club-asesores-prototipo.vercel.app/og.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Mismo arranque que dentro de la fortaleza (ver Fortaleza.astro): con movimiento
         permitido, la Puerta tambien se descubre desde el velo. Asi Cerrar sesion cierra
         en el Patio y abre aqui, sin costura. -->
    <script is:inline>
      if (matchMedia('(prefers-reduced-motion: no-preference)').matches) document.documentElement.classList.add('entra');
    </script>
  </head>
  <body>
    <!-- La Puerta va sin el shell (aqui no hay navegacion), pero el velo es de la casa -->
    <Velo />

    <main class="login" style={`background-image:url('${POSTER}')`}>
      <!-- El control de silencio, a la vista ANTES de que suene nada: aqui ya hay
           efectos de hover y click, y la musica arranca al cruzar. -->
      <button class="sonido login__sonido" type="button" aria-label="Silenciar el sonido" aria-pressed="false" data-augmented-ui="tl-clip br-clip">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
          <path class="sonido__bocina" d="M4 9.5h3.6L12 5.6v12.8L7.6 14.5H4z" />
          <g class="sonido__ondas">
            <path d="M15.2 9.4a3.6 3.6 0 0 1 0 5.2" />
            <path d="M17.8 7.2a7 7 0 0 1 0 9.6" />
          </g>
          <path class="sonido__tacha" d="M15.5 9.5l5 5m0-5l-5 5" />
        </svg>
      </button>
      <video class="bg" muted loop playsinline preload="none" poster={POSTER} aria-hidden="true" data-src={VIDEO}></video>
      <div class="veil" aria-hidden="true"></div>

      <div class="wrap">
        <section class="acceso">
          <img class="logo" src="/assets/marca/logo-club.webp" alt="Club de la Asesoría" />

          <h1 class="display titulo">Entra en tu fortaleza</h1>
          <p class="lead">La fortaleza sigue en pie, pero hay una grieta nueva. Pasa, te enseño dónde.</p>
          <p class="lead-firma">Nara, guardiana de la fortaleza</p>

          <form class="form" action="/dashboard" method="get">
            <div class="campo">
              <label for="correo">Correo electrónico</label>
              <input id="correo" type="email" name="email" required autocomplete="username" spellcheck="false" autocapitalize="none" placeholder="tu@asesoria.com" data-augmented-ui={RANURA} />
            </div>
            <div class="campo">
              <label for="clave">Contraseña</label>
              <!-- Sin name a proposito: el fallback GET sin JS meteria la contrasena en la URL.
                   Los gestores la reconocen por type y autocomplete. -->
              <input id="clave" type="password" required autocomplete="current-password" placeholder="Tu contraseña" data-augmented-ui={RANURA} />
            </div>

            <a class="enlace olvido" href="#">He olvidado mi contraseña</a>

            <button class="btn" type="submit" data-sonido="entrar" data-augmented-ui="l-clip-y r-clip-y">Entrar</button>
          </form>

          <p class="nota">
            El acceso al Club es por invitación. Si ya eres miembro y no consigues entrar, escríbenos y te abrimos la puerta.
          </p>
        </section>

        <figure class="nara">
          <img src="/assets/personajes/ui/nara-umbral.webp" alt="Nara, la guardiana de la fortaleza" width="1165" height="1560" />
          <span class="aura" aria-hidden="true"></span>
        </figure>
      </div>
    </main>

    <script>
      import { montarCursor } from '../scripts/cursor.js';
      import { montarVelo, cruzar } from '../scripts/velo.js';
      import { cablearInterfaz, alternarSonido, estaSilenciado, sonar } from '../scripts/audio.js';

      montarCursor();
      montarVelo();
      cablearInterfaz();

      // El video de la escena solo se pide si hay movimiento permitido: antes, con
      // prefers-reduced-motion, se descargaba 1.2MB de webm que nunca se veia.
      const bg = document.querySelector<HTMLVideoElement>('.bg');
      if (bg && matchMedia('(prefers-reduced-motion: no-preference)').matches) {
        bg.src = bg.dataset.src || '';
        bg.play().catch(() => {});
      }

      // Entrar es EL gesto: desbloquea el audio, cierra el velo y deja la musica querida.
      // preventDefault SIEMPRE: con los campos nombrados, el GET nativo ensuciaria la
      // URL, y la rama silenciada tambien debe cruzar con su velo (antes navegaba en seco).
      const form = document.querySelector('.form');
      if (form) {
        const btn = form.querySelector<HTMLButtonElement>('.btn');
        // El golpe de puerta lo dispara el pointerdown del boton (data-sonido="entrar").
        // Con Enter desde un campo no hay pointerdown: el submit lo repone.
        let golpeDado = false;
        btn?.addEventListener('pointerdown', () => { golpeDado = true; });

        form.addEventListener('submit', (e) => {
          e.preventDefault();
          const silencio = estaSilenciado();
          if (!silencio) {
            localStorage.setItem('fortaleza-audio', 'on');
            if (!golpeDado) sonar('entrar', 0.4);
          }
          if (btn) { btn.disabled = true; btn.textContent = 'Abriendo la puerta'; }
          // El velo es el de la casa, pero aqui la espera se fuerza: con sonido acompana
          // al golpe de puerta (~550ms) y en silencio cruza corto. Tras la Puerta, la entrega
          // (onboarding): nombre, avatar y el tour antes de caer en el Patio.
          cruzar('/onboarding', silencio ? 280 : 550);
        });
      }

      // El mismo control de silencio del HUD, aqui a la vista desde el primer segundo
      const sonido = document.querySelector('.sonido');
      if (sonido) {
        const pintar = () => {
          const off = estaSilenciado();
          sonido.setAttribute('aria-pressed', String(off));
          sonido.setAttribute('aria-label', off ? 'Activar el sonido' : 'Silenciar el sonido');
        };
        pintar();
        sonido.addEventListener('click', () => { alternarSonido(); pintar(); });
      }
    </script>

    <style is:global>
      /* Los tokens y los componentes base salen de src/styles/tokens.css */

      /* Escena de fondo: el porton del castro */
      .login { position: relative; min-height: 100svh; overflow: hidden; background-size: cover; background-position: center; }
      /* El silencio flota sobre la escena, alineado con el margen del contenido */
      .login__sonido { position: absolute; top: 20px; right: max(3vw, 20px); z-index: 3; }

      /* La columna entra escalonada, como quien llega al umbral. Solo con movimiento
         permitido: sin la preferencia, el estado servido ya es el final. El boton de
         silencio queda fuera a proposito: el control se ve desde el primer frame. */
      @media (prefers-reduced-motion: no-preference) {
        .logo, .titulo, .lead, .lead-firma, .campo, .olvido, .form .btn, .nota, .nara {
          animation: umbral 0.5s ease-out both;
        }
        .titulo { animation-delay: 70ms; }
        .lead { animation-delay: 140ms; }
        .lead-firma { animation-delay: 180ms; }
        .campo:nth-of-type(1) { animation-delay: 210ms; }
        .campo:nth-of-type(2) { animation-delay: 260ms; }
        .olvido { animation-delay: 310ms; }
        .form .btn { animation-delay: 360ms; }
        .nota { animation-delay: 430ms; }
        /* Nara no se desplaza: ella ya estaba en el umbral, solo se revela */
        .nara { animation-name: revela; animation-duration: 0.9s; animation-delay: 150ms; }
        @keyframes umbral {
          from { opacity: 0; transform: translateY(10px); }
          to { opacity: 1; transform: translateY(0); }
        }
        @keyframes revela {
          from { opacity: 0; }
          to { opacity: 1; }
        }
      }
      .bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
      .veil {
        position: absolute; inset: 0; z-index: 1;
        background:
          linear-gradient(to right, rgba(9,13,20,0.96) 0%, rgba(9,13,20,0.82) 34%, rgba(9,13,20,0.25) 66%, rgba(9,13,20,0.55) 100%),
          linear-gradient(to top, rgba(9,13,20,0.9) 0%, transparent 45%);
      }

      .wrap {
        position: relative; z-index: 2;
        width: min(1240px, 92vw); margin: 0 auto; min-height: 100svh;
        display: grid; grid-template-columns: minmax(340px, 460px) 1fr;
        align-items: center; gap: clamp(24px, 5vw, 72px);
      }

      /* Columna de acceso (no confundir con .panel de tokens, que es la superficie de los modulos) */
      .acceso { padding: clamp(14px, 3vh, 56px) 0; }
      .logo { width: clamp(96px, min(12vw, 17vh), 168px); height: auto; display: block; margin: 0 0 clamp(14px, 3vh, 40px); }
      .titulo { margin: 0; font-size: clamp(1.6rem, min(3.4vw, 4.4vh), 3.1rem); color: var(--bone); }
      .lead { margin: clamp(8px, 1.4vh, 14px) 0 0; font-family: var(--italic); font-style: italic; font-size: clamp(1.05rem, min(1.5vw, 2.1vh), 1.35rem); color: var(--moon); line-height: 1.45; }
      .lead-firma { margin: 0.7rem 0 clamp(16px, 3.2vh, 40px); font-size: 0.74rem; letter-spacing: 0.06em; color: var(--mist); }

      /* Formulario: cada campo es una ranura del mecanismo de la puerta */
      .form { display: flex; flex-direction: column; gap: clamp(12px, 2vh, 18px); }
      .campo { display: flex; flex-direction: column; gap: 9px; }
      .campo label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--mist); }
      .campo input {
        --aug-tl: 10px; --aug-br: 10px;
        --aug-border-all: 1px;
        --aug-border-bg: rgba(194,205,214,0.42);
        width: 100%; padding: clamp(11px, 1.8vh, 14px) 16px; border: 0;
        color: var(--bone); font-family: var(--sans); font-size: 1rem;
        /* Hendidura: arriba mas oscuro, como ranura tallada en la piedra */
        background: linear-gradient(180deg, rgba(9,13,20,0.8), rgba(20,32,46,0.55));
        transition: background 0.25s ease;
      }
      .campo input::placeholder { color: rgba(140,160,176,0.5); }
      .campo input:hover { --aug-border-bg: rgba(194,205,214,0.5); }
      /* Al escribir, la ranura se enciende: es el mismo cian que dice "esto esta vivo" */
      .campo input:focus {
        outline: none;
        --aug-border-bg: var(--cyan);
        background: linear-gradient(180deg, rgba(16,30,44,0.85), rgba(63,169,201,0.13));
      }

      .olvido { align-self: flex-start; margin-top: -2px; }

      /* El boton hereda de tokens.css; aqui solo su sitio en el formulario */
      .btn { margin-top: clamp(6px, 1.2vh, 10px); padding: clamp(12px, 1.9vh, 15px) 22px; font-size: 0.86rem; }

      .nota { margin: clamp(14px, 2.6vh, 38px) 0 0; max-width: 40ch; font-size: 0.82rem; line-height: 1.55; color: var(--mist); }

      /* Nara en el umbral */
      .nara { position: relative; margin: 0; align-self: end; justify-self: center; pointer-events: none; }
      .nara .aura { left: 50%; top: 47%; width: 17%; }
      .nara img { display: block; height: clamp(380px, 72vh, 780px); width: auto; object-fit: contain; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.7)); }

      /* Una sola columna: cuando el ancho aprieta (movil/tablet) o cuando la altura
         aprieta (apaisado). Nara se retira para no comer la pantalla; el velo pasa a
         oscurecer de abajo arriba, que es como se apila el contenido. */
      @media (max-width: 860px), (max-height: 480px) {
        .wrap { grid-template-columns: 1fr; align-items: start; padding: clamp(28px, 6vh, 56px) 0; }
        .veil { background: linear-gradient(to top, rgba(9,13,20,0.96) 30%, rgba(9,13,20,0.72) 70%, rgba(9,13,20,0.5) 100%); }
        .nara { display: none; }
        .acceso { padding-top: clamp(16px, 4vh, 32px); }
      }

      /* Apaisado y poca altura: el mismo apilado, pero comprimido. La columna se ceñe
         para no estirarse a lo ancho del portón, y el ritmo vertical se aprieta para
         que el formulario entero quede a un dedo de scroll, nunca cortado. */
      @media (max-height: 480px) {
        .wrap { min-height: 0; padding: clamp(14px, 5vh, 24px) 0 clamp(20px, 6vh, 28px); }
        .acceso { max-width: 560px; margin: 0 auto; padding: 0; }
        .logo { width: clamp(56px, 13vh, 84px); margin-bottom: clamp(8px, 2vh, 14px); }
        .titulo { font-size: clamp(1.4rem, 6.4vh, 2rem); }
        .lead { margin-top: clamp(4px, 1.4vh, 8px); font-size: clamp(0.95rem, 3.4vh, 1.1rem); line-height: 1.4; }
        .lead-firma { margin: 0.5rem 0 clamp(10px, 2.6vh, 16px); }
        .form { gap: clamp(8px, 1.8vh, 12px); }
        .campo { gap: 6px; }
        .campo input { padding: 11px 14px; }
        .btn { margin-top: clamp(4px, 1.2vh, 8px); }
        .nota { margin-top: clamp(12px, 2.8vh, 18px); max-width: none; }
      }
      @media (prefers-reduced-motion: reduce) { .bg { display: none; } }
    </style>
  </body>
</html>
