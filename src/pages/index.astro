---
// Login (Puerta de la Fortaleza). Primera pantalla del prototipo.
// Solo estetica: los campos no envian nada y el boton lleva al Dashboard.
// Mas adelante, al terminar el acceso, disparara el Onboarding.

const POSTER = '/assets/mapa-escenas/patio-entrada.webp';
const VIDEO = '/assets/animaciones/patio-entrada.webm';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Club de la Asesoría</title>
    <meta name="description" content="Acceso al Club de la Asesoría." />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@500;600&family=Cormorant+Garamond:ital,wght@1,400;1,500&family=Hanken+Grotesk:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="login" style={`background-image:url('${POSTER}')`}>
      <video class="bg" autoplay muted loop playsinline preload="auto" poster={POSTER} aria-hidden="true">
        <source src={VIDEO} type="video/webm" />
      </video>
      <div class="veil" aria-hidden="true"></div>

      <div class="wrap">
        <section class="panel">
          <img class="logo" src="/assets/marca/logo-club.webp" alt="Club de la Asesoría" />

          <h1 class="display titulo">Entra en tu fortaleza</h1>
          <p class="lead">Nara ya ha encontrado la primera grieta.</p>

          <form class="form" action="/dashboard" method="get">
            <div class="campo">
              <label for="correo">Correo electrónico</label>
              <input id="correo" type="email" autocomplete="username" placeholder="tu@asesoria.com" />
            </div>
            <div class="campo">
              <label for="clave">Contraseña</label>
              <input id="clave" type="password" autocomplete="current-password" placeholder="Tu contraseña" />
            </div>

            <a class="olvido" href="#">He olvidado mi contraseña</a>

            <button class="btn" type="submit">Entrar</button>
          </form>

          <p class="nota">
            El acceso al Club es por invitación. Si ya eres miembro y no consigues entrar, escríbenos y te abrimos la puerta.
          </p>
        </section>

        <figure class="nara">
          <img src="/assets/personajes/nara.webp" alt="Nara, la guardiana de la fortaleza" />
        </figure>
      </div>
    </main>

    <style is:global>
      :root {
        --ink: #090D14; --night: #0C1019; --night2: #14202E; --steel: #3A4654;
        --cyan: #3FA9C9; --aqua: #5FD0E0; --silver: #C2CDD6; --moon: #AEC6D8;
        --bone: #EAF1F6; --mist: #8CA0B0;
        --amber: #E8A93F; --amber-2: #F2C471;
        --serif: 'Cinzel', Georgia, serif;
        --sans: 'Hanken Grotesk', system-ui, sans-serif;
        --italic: 'Cormorant Garamond', Georgia, serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: var(--ink); color: var(--bone); font-family: var(--sans); -webkit-font-smoothing: antialiased; }
      ::selection { background: var(--amber); color: var(--ink); }
      .display { font-family: var(--serif); font-weight: 600; letter-spacing: 0.03em; line-height: 1.08; }

      /* Escena de fondo: el porton del castro */
      .login { position: relative; min-height: 100svh; overflow: hidden; background-size: cover; background-position: center; }
      .bg { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
      .veil {
        position: absolute; inset: 0; z-index: 1;
        background:
          linear-gradient(to right, rgba(9,13,20,0.96) 0%, rgba(9,13,20,0.82) 34%, rgba(9,13,20,0.25) 66%, rgba(9,13,20,0.55) 100%),
          linear-gradient(to top, rgba(9,13,20,0.9) 0%, transparent 45%);
      }

      .wrap {
        position: relative; z-index: 2;
        width: min(1240px, 92vw); margin: 0 auto; min-height: 100svh;
        display: grid; grid-template-columns: minmax(340px, 460px) 1fr;
        align-items: center; gap: clamp(24px, 5vw, 72px);
      }

      /* Panel de acceso */
      .panel { padding: clamp(28px, 5vh, 56px) 0; }
      .logo { width: clamp(120px, 12vw, 168px); height: auto; display: block; margin: 0 0 clamp(24px, 4vh, 40px); }
      .titulo { margin: 0; font-size: clamp(2.1rem, 3.4vw, 3.1rem); color: var(--bone); }
      .lead { margin: 0.9rem 0 clamp(26px, 4vh, 40px); font-family: var(--italic); font-style: italic; font-size: clamp(1.1rem, 1.5vw, 1.35rem); color: var(--moon); line-height: 1.45; }

      /* Formulario */
      .form { display: flex; flex-direction: column; gap: 18px; }
      .campo { display: flex; flex-direction: column; gap: 8px; }
      .campo label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.18em; color: var(--mist); }
      .campo input {
        width: 100%; padding: 13px 2px; color: var(--bone); font-family: var(--sans); font-size: 1rem;
        background: transparent; border: 0; border-bottom: 1px solid rgba(194,205,214,0.28);
        transition: border-color 0.25s ease, box-shadow 0.25s ease;
      }
      .campo input::placeholder { color: rgba(140,160,176,0.5); }
      .campo input:hover { border-bottom-color: rgba(194,205,214,0.5); }
      .campo input:focus { outline: none; border-bottom-color: var(--cyan); box-shadow: 0 1px 0 0 var(--cyan), 0 6px 22px -12px var(--cyan); }

      .olvido { align-self: flex-start; margin-top: -2px; font-size: 0.82rem; color: var(--mist); text-decoration: none; border-bottom: 1px solid transparent; transition: color 0.2s ease, border-color 0.2s ease; }
      .olvido:hover { color: var(--moon); border-bottom-color: rgba(174,198,216,0.5); }

      .btn {
        margin-top: 10px; padding: 15px 22px; border: 0; border-radius: 3px; cursor: pointer;
        background: linear-gradient(180deg, var(--amber-2), var(--amber));
        color: #1B1206; font-family: var(--sans); font-weight: 600; font-size: 0.88rem;
        text-transform: uppercase; letter-spacing: 0.2em; text-align: center; text-decoration: none;
        box-shadow: 0 10px 30px -12px rgba(232,169,63,0.75);
        transition: transform 0.18s ease, box-shadow 0.25s ease, filter 0.2s ease;
      }
      .btn:hover { filter: brightness(1.06); box-shadow: 0 14px 38px -12px rgba(232,169,63,0.9); transform: translateY(-1px); }
      .btn:active { transform: translateY(0); }
      .btn:focus-visible { outline: 2px solid var(--aqua); outline-offset: 3px; }

      .nota { margin: clamp(26px, 4vh, 38px) 0 0; max-width: 40ch; font-size: 0.82rem; line-height: 1.6; color: var(--mist); }

      /* Nara en el umbral */
      .nara { margin: 0; align-self: end; justify-self: center; pointer-events: none; }
      .nara img { display: block; height: clamp(380px, 72vh, 780px); width: auto; object-fit: contain; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.7)); }

      @media (max-width: 900px) {
        .wrap { grid-template-columns: 1fr; align-items: start; padding: clamp(28px, 6vh, 56px) 0; }
        .veil { background: linear-gradient(to top, rgba(9,13,20,0.96) 30%, rgba(9,13,20,0.72) 70%, rgba(9,13,20,0.5) 100%); }
        .nara { display: none; }
        .panel { padding-top: clamp(16px, 4vh, 32px); }
      }
      @media (prefers-reduced-motion: reduce) { .bg { display: none; } }
    </style>
  </body>
</html>
