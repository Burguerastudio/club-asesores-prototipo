---
// Recompensas (P10). El Shop del sistema, aterrizado en La Fortaleza.
// Cuelga del avatar del HUD: lo que abres con tus PF es tuyo, no un sitio del castro.
//
// NO ES UNA TIENDA (mecanicas-gamificacion 6, 2026-07-20). Es una ESCALERA: al llegar al
// umbral la recompensa se abre, y los PF no se gastan. El documento lo dice literal:
// "un sistema de desbloqueo por umbral de puntos, no una tienda de canje".
//
// Eso cambia de que va la pantalla. Ya no es una decision de en que gastas (eso era la
// version anterior, con la economia vieja): es un camino donde todo lo de arriba llega si
// sostienes el avance. Por eso no hay "lo que te quedaria": no te quedas sin nada.
//
// Lo que aun no alcanzas SE VE, con cuanto falta. Es lo que dice que hay camino.
import Fortaleza from '../layouts/Fortaleza.astro';
import Motas from '../components/Motas.astro';
import { asesora, recompensas, abierta, siguienteRecompensa } from '../data/demo.js';

const catalogo = recompensas.map((r) => ({
  ...r,
  abierta: abierta(r),
  faltan: Math.max(0, r.umbral - asesora.pf),
}));

// La siguiente que cae: la meta corta. Sale de demo.js para que no haya dos criterios.
const siguiente = siguienteRecompensa && catalogo.find((r) => r.slug === siguienteRecompensa.slug);
const abiertas = catalogo.filter((r) => r.abierta).length;

const F_AZULEJO = 'tl-clip br-clip border';
const F_BOTON = 'l-clip-y r-clip-y';
---

<Fortaleza title="Recompensas, Club de la Asesoría" activa="/recompensas">
  <!-- EL SALDO. Arriba, como manda el sistema: es contra lo que se lee todo lo demas.
       Sin placa: es un dato tuyo, no un objeto clavado en la fortaleza. -->
  <header class="saldo">
    <div class="saldo__d">
      <p class="saldo__k">Tus Puntos de Fortaleza</p>
      <p class="saldo__n">
        <!-- El CUMULO: el deck dice "fragmento suelto y cumulo para el medidor". Y aqui
             es literalmente un medidor: con umbral, los PF no bajan nunca. -->
        <img src="/assets/moneda/ui/pf-cumulo.webp" alt="" aria-hidden="true" width="512" height="247" />
        <!-- data-yo-pf: los PF son un dato GLOBAL, y el director los reescribe segun el rango
             del conmutador (igual que en el HUD). Sin este gancho el saldo se quedaba clavado
             en el del build. En rango 3 pinta 725, identico. -->
        <b data-yo-pf>{asesora.pf.toLocaleString('es-ES')}</b>
      </p>
      <p class="saldo__l">
        <span data-rec-abiertas>{abiertas}</span> de {catalogo.length} recompensas abiertas. No se gastan: cada umbral que
        cruzas queda abierto para siempre.
      </p>
    </div>

    {siguiente && (
      <div class="proxima" data-augmented-ui={F_AZULEJO}>
        <img src={siguiente.img} alt="" aria-hidden="true" width="380" height="420" />
        <div class="proxima__d">
          <p class="rotulo">La siguiente</p>
          <b class="proxima__n">{siguiente.nombre}</b>
          <!-- Sin "o llegar a Estratega": el rango abre la puerta, no regala la
               recompensa, y decirlo prometia algo falso. Ver demo.js. -->
          <span class="proxima__f">Te faltan <b>{siguiente.faltan.toLocaleString('es-ES')} PF</b></span>
        </div>
      </div>
    )}
  </header>

  <!-- EL CATALOGO -->
  <section class="cat" aria-label="Catálogo de recompensas">
    <ul class="cat__l">
      {catalogo.map((r) => (
        <li class="rec-caja">
          <!-- Las motas van FUERA de la ficha: augmented-ui la recorta y dentro quedarian
               encerradas. Es la caja de siempre (ver docs/DESIGN.md). Solo las sueltan las
               que ya estan abiertas: una ficha apagada no desprende luz. -->
          {r.abierta && <Motas base={4} refuerzo={4} />}

          <div class={`rec${r.abierta ? ' is-tuya' : ''}`} data-umbral={r.umbral} data-augmented-ui={F_AZULEJO}>
          <!-- La hornacina: el mismo hueco de piedra para las seis. Es lo que las hace
               leer como un set aunque cada pieza tenga su forma (el cofre es alto, el
               pergamino ancho, el disco redondo). CSS puro, que los ornamentos no son
               imagenes. -->
          <div class="rec__nicho">
            <img src={r.img} alt="" aria-hidden="true" width="380" height="420" loading="lazy" />
          </div>

          <!-- El nombre y el umbral son la misma cosa (que es y cuando se abre), asi que
               van juntos y no separados por aire: el umbral cuelga del nombre. -->
          <div class="rec__d">
            <b class="rec__n">{r.nombre}</b>
            <p class="rec__pf">
              <!-- El FRAGMENTO suelto, no el cumulo: un umbral es una cantidad, no un
                   medidor (el deck separa los dos usos). -->
              <img src="/assets/moneda/ui/pf.webp" alt="" aria-hidden="true" width="270" height="512" />
              <b>{r.umbral.toLocaleString('es-ES')}</b>
              <span>PF</span>
            </p>
            <!-- Que es, en una linea. Lo trae mecanicas-gamificacion 6, y hasta hoy no
                 existia en ningun sitio: las fichas ensenaban un nombre y un numero. -->
            <p class="rec__q">{r.que}</p>
          </div>

          <div class="rec__pie">
            {r.abierta ? (
              <!-- Abrirla la resuelve el plugin: aqui no navega, avisa. Y es ABRIR, no
                   reclamar: con umbral no se canjea nada, se accede a lo que ya es tuyo. -->
              <button
                class="btn-linea rec__b"
                type="button"
                data-integracion="gamipress:abrir-recompensa"
                data-aviso="Se abre sola cuando la fortaleza esté conectada."
                data-augmented-ui={F_BOTON}
              >
                Abrir recompensa
                <span class="pista" role="tooltip" aria-live="polite" data-augmented-ui="tl-clip br-clip border">Abrir</span>
              </button>
            ) : (
              <!-- Lo que aun no alcanzas no se esconde: se ve, y dice cuanto falta -->
              <span class="rec__falta">Te faltan <b>{r.faltan.toLocaleString('es-ES')} PF</b></span>
            )}
          </div>
          </div>
        </li>
      ))}
    </ul>
  </section>
</Fortaleza>

<script>
  // El aviso de lo que resuelve el plugin ya lo monta el layout (integracion.js): los
  // botones solo tienen que llevar data-integracion.
  //
  // EL CONMUTADOR DE DEMO. El build pinta el rango 3 (725 PF: abiertas las de 150, 300 y 500).
  // Al recargar con otro rango, esto vuelve a derivar el estado PROFUNDO de Recompensas a
  // partir de los PF elegidos, sobre el DOM ya pintado. Lo GLOBAL (HUD, PF del saldo via
  // data-yo-pf, rango, barra) lo hace el director; esto reescribe solo lo de esta pantalla:
  //   - is-tuya de cada ficha (abierta si PF >= su umbral)
  //   - el pie: boton "Abrir" en las abiertas, aviso "Te faltan X PF" en las cerradas
  //   - las motas, que solo desprenden las abiertas
  //   - el contador "X de 6" y el bloque "La siguiente" (la primera aun no alcanzada)
  // Con umbral no se gasta nada: cruzar es una comparacion, no una resta de saldo.
  import { estadoDemo } from '../scripts/demo-director.js';

  (() => {
    const pf = estadoDemo().pf;

    // Moldes del pie y de las motas, clonados ANTES de tocar el DOM: el rango 3 siempre pinta
    // fichas abiertas (con boton y motas) y cerradas (con aviso), asi que ambos existen y los
    // reusamos al cambiar de rango sin duplicar su markup.
    const moldeBtn = document.querySelector('.rec__b')?.cloneNode(true);
    const moldeFalta = document.querySelector('.rec__falta')?.cloneNode(true);
    const moldeMotas = document.querySelector('.motas')?.cloneNode(true);

    let abiertas = 0;
    let siguienteCard = null; // la primera ficha aun no alcanzada, para "La siguiente"

    document.querySelectorAll('.rec').forEach((rec) => {
      const umbral = Number(rec.dataset.umbral);
      const abierta = pf >= umbral;
      const caja = rec.parentElement; // .rec-caja: las motas cuelgan de aqui, fuera del recorte

      rec.classList.toggle('is-tuya', abierta);

      // El pie: cada ficha tiene O boton O aviso, nunca los dos. Solo se cambia si el estado le
      // da la vuelta al que pinto el build.
      const pie = rec.querySelector('.rec__pie');
      if (abierta) {
        if (pie && moldeBtn && !pie.querySelector('.rec__b')) pie.replaceChildren(moldeBtn.cloneNode(true));
      } else if (pie) {
        let falta = pie.querySelector('.rec__falta');
        if (!falta && moldeFalta) { falta = moldeFalta.cloneNode(true); pie.replaceChildren(falta); }
        // umbral - pf es positivo aqui (la ficha esta cerrada): es lo que le falta al avance
        // para llegar, no un saldo que se descuente.
        if (falta) falta.querySelector('b').textContent = (umbral - pf).toLocaleString('es-ES') + ' PF';
        if (!siguienteCard) siguienteCard = rec;
      }

      // Las motas solo las desprenden las abiertas: una ficha apagada no da luz.
      const motas = caja && caja.querySelector('.motas');
      if (abierta) {
        if (caja && moldeMotas && !motas) caja.insertBefore(moldeMotas.cloneNode(true), rec);
      } else if (motas) {
        motas.remove();
      }

      if (abierta) abiertas++;
    });

    // El contador de cabecera "X de 6 recompensas abiertas".
    const cont = document.querySelector('[data-rec-abiertas]');
    if (cont) cont.textContent = String(abiertas);

    // "La siguiente": la primera aun no alcanzada. Copiamos su nombre e imagen de su propia
    // ficha (ya pintada), asi no inventamos ningun texto. Si estan todas abiertas no hay
    // siguiente y el bloque se retira (su display:flex gana al [hidden], por eso se quita del
    // DOM); el contador "6 de 6" ya cuenta que la escalera esta completa.
    const proxima = document.querySelector('.proxima');
    if (proxima) {
      if (!siguienteCard) {
        proxima.remove();
      } else {
        const umbralSig = Number(siguienteCard.dataset.umbral);
        const nombre = siguienteCard.querySelector('.rec__n')?.textContent;
        const imgSrc = siguienteCard.querySelector('.rec__nicho img')?.getAttribute('src');
        const nEl = proxima.querySelector('.proxima__n');
        const imgEl = proxima.querySelector('img');
        const fEl = proxima.querySelector('.proxima__f b');
        if (nEl && nombre != null) nEl.textContent = nombre;
        if (imgEl && imgSrc) imgEl.setAttribute('src', imgSrc);
        if (fEl) fEl.textContent = (umbralSig - pf).toLocaleString('es-ES') + ' PF';
      }
    }
  })();
</script>

<style is:global>
  /* El layout reserva hasta 88px de aire abajo, que aqui es hueco muerto: esta pantalla
     esta hecha para caber. Mismo caso que El asesor. */
  .contenido:has(.saldo) { padding-bottom: clamp(18px, 2.5vh, 28px); }

  .entra .saldo, .entra .cat { animation: destape-rec 0.5s ease-out both; }
  .entra .cat { animation-delay: 0.14s; }
  @keyframes destape-rec {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* EL SALDO */
  .saldo {
    display: flex; align-items: center; justify-content: space-between;
    gap: clamp(20px, 3vw, 48px); flex-wrap: wrap;
    margin-bottom: clamp(14px, 2vh, 24px);
  }
  .saldo__k { margin: 0; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.13em; color: var(--mist); }
  .saldo__n { display: flex; align-items: center; gap: 12px; margin: 6px 0 0; }
  .saldo__n img { width: clamp(28px, 2.6vw, 38px); height: auto; object-fit: contain; }
  .saldo__n b {
    font-family: var(--serif); font-weight: 600; letter-spacing: 0.02em;
    font-size: clamp(2rem, 3.6vw, 3rem); color: var(--aqua);
  }
  .saldo__l { margin: 8px 0 0; max-width: 52ch; font-size: 0.86rem; color: var(--mist); }

  /* Que es la recompensa. Sin esto, la ficha era un nombre y un numero. */
  .rec__q {
    margin: 7px 0 0; font-size: 0.76rem; line-height: 1.45; color: var(--mist);
  }
  .rec.is-tuya .rec__q { color: var(--moon); }

  /* La siguiente que cae: la meta corta. En placa porque es un objeto, no un dato. */
  .proxima {
    --aug-tl: 12px; --aug-br: 12px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.26);
    display: flex; align-items: center; gap: 14px;
    padding: 12px 18px 12px 12px;
    background: linear-gradient(180deg, rgba(20,32,46,0.55), rgba(9,13,20,0.4));
  }
  .proxima img { width: clamp(48px, 4.4vw, 62px); height: auto; object-fit: contain; filter: grayscale(1) brightness(0.5); opacity: 0.7; }
  .proxima__d { display: flex; flex-direction: column; gap: 3px; }
  .proxima__n { font-size: 0.88rem; color: var(--bone); }
  .proxima__f { font-size: 0.76rem; color: var(--mist); }
  .proxima__f b { color: var(--aqua); }

  /* EL CATALOGO. Tres columnas: las seis caben en dos filas y sin scroll. */
  .cat__l {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(3, 1fr); gap: clamp(9px, 1vw, 14px);
  }
  /* La caja: deja salir a las motas del recorte de la ficha (ver DESIGN.md) */
  .rec-caja { position: relative; display: flex; }
  /* LA FICHA. Vertical y con la pieza mandando: son objetos, y el catalogo esta para
     lucirlos. En fila iban a 60px, de miniatura, con media pantalla vacia debajo. */
  .rec {
    --aug-tl: 12px; --aug-br: 12px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.2);
    flex: 1;
    display: flex; flex-direction: column; align-items: center; text-align: center;
    padding: clamp(12px, 1.4vw, 18px) 16px clamp(12px, 1.4vw, 16px);
    /* Con GRANO, como las placas: es piedra, no un rectangulo de color. El grano va
       primero para que quede por encima de la luz del fondo. */
    background-color: rgba(11,17,27,0.6);
    background-image:
      var(--grano),
      radial-gradient(ellipse 70% 45% at 50% 22%, rgba(63,169,201,0.11), transparent 70%),
      linear-gradient(180deg, rgba(104,132,162,0.13), rgba(9,13,20,0) 60%);
    transition: background-color 0.25s ease;
  }
  /* Recompensa abierta = un sello cruzado: su canto va en oro (trofeo), no en ambar (accion). */
  .rec.is-tuya { --aug-border-bg: rgba(201,162,75,0.5); }
  .rec-caja:hover .rec.is-tuya { background-color: rgba(20,32,46,0.72); }

  /* LA HORNACINA. El mismo hueco para las seis: cuadrado, con su luz al fondo y su sombra
     en el suelo. Es lo que las hace leer como un set aunque cada pieza tenga su forma.
     El alto FIJO ademas alinea los seis nombres, que si no cada pieza empuja el suyo. */
  .rec__nicho {
    position: relative;
    width: 100%; height: clamp(118px, 10.4vw, 150px);
    padding: 0 4% 4px;
    margin-bottom: clamp(8px, 1vw, 12px);
  }
  /* La luz del fondo del hueco */
  .rec__nicho::before {
    content: ''; position: absolute; left: 50%; top: 46%; transform: translate(-50%, -50%);
    width: 74%; height: 74%; border-radius: 50%;
    background: radial-gradient(closest-side, rgba(95,208,224,0.16), transparent 72%);
  }
  /* La sombra en el suelo: la pieza se APOYA, no flota */
  .rec__nicho::after {
    content: ''; position: absolute; left: 50%; bottom: 2px; transform: translateX(-50%);
    width: 62%; height: 12px;
    background: radial-gradient(ellipse at center, rgba(0,0,0,0.6), transparent 70%);
  }
  /* La imagen LLENA la hornacina y la encaja object-fit, en vez de ir a su tamano con
     max-height: en un grid item centrado el max-height en % no resuelve (el porcentaje
     cae contra un alto indefinido y el navegador lo ignora), y las piezas salian a
     tamano natural pisando el texto. Asi las seis ocupan la misma caja exacta. */
  .rec__nicho img {
    position: relative;
    width: 100%; height: 100%; object-fit: contain; object-position: center bottom;
    transition: transform 0.25s ease;
  }
  .rec:not(.is-tuya) .rec__nicho img { filter: grayscale(1) brightness(0.42); opacity: 0.55; }
  .rec:not(.is-tuya) .rec__nicho::before { background: radial-gradient(closest-side, rgba(194,205,214,0.06), transparent 72%); }
  .rec.is-tuya .rec__nicho img { filter: drop-shadow(0 6px 14px rgba(0,0,0,0.7)); }
  .rec.is-tuya:hover .rec__nicho img { transform: translateY(-4px) scale(1.04); }

  /* Dos lineas reservadas: hay nombres de una linea y de dos, y sin el hueco fijo el
     precio de cada ficha caia a una altura distinta. */
  /* El nombre y el precio son la misma cosa (que es y cuanto vale): el bloque los
     mantiene pegados, y el hueco de dos lineas del nombre alinea los seis precios. */
  .rec__d { display: flex; flex-direction: column; gap: 2px; }
  .rec__n {
    font-family: var(--serif); font-weight: 600; letter-spacing: 0.02em;
    font-size: 0.94rem; line-height: 1.3; color: var(--moon); min-height: 2.6em;
  }
  .rec.is-tuya .rec__n { color: var(--bone); }

  /* EL PRECIO, con su cristal: es la moneda de la casa y en el HUD se lee asi */
  .rec__pf { display: flex; align-items: center; justify-content: center; gap: 7px; margin: 0; }
  .rec__pf img { width: 17px; height: auto; object-fit: contain; }
  /* El PF va en cian, como el contador de PF del HUD: es el mismo recurso, no debe cambiar de
     color unos centimetros mas abajo. El ambar se reserva para la accion de la pantalla. */
  .rec__pf b {
    font-family: var(--serif); font-weight: 600; letter-spacing: 0.02em;
    font-size: 1.34rem; color: var(--aqua); line-height: 1;
  }
  .rec__pf span { font-size: 0.68rem; letter-spacing: 0.1em; color: var(--aqua); opacity: 0.75; }
  .rec:not(.is-tuya) .rec__pf b, .rec:not(.is-tuya) .rec__pf span { color: var(--mist); }
  .rec:not(.is-tuya) .rec__pf img { filter: grayscale(1) brightness(0.6); opacity: 0.6; }

  /* El pie SIEMPRE abajo del todo (margin-top: auto), no pegado al texto: la descripcion
     ocupa una o dos lineas segun la recompensa, y sin esto los seis botones caian a
     alturas distintas dentro de fichas que miden lo mismo. */
  .rec__pie { margin-top: auto; padding-top: clamp(9px, 1.1vw, 14px); min-height: 36px; display: flex; align-items: center; }
  .rec__b { position: relative; padding-left: 30px; padding-right: 30px; }
  .rec__b .pista { text-transform: none; letter-spacing: 0; font-weight: 400; }
  /* Aqui la pildora es SOLO el aviso: el boton ya dice lo que hace */
  .rec__b:hover > .pista { opacity: 0; visibility: hidden; }
  .rec__b > .pista.is-dicha { opacity: 1; visibility: visible; }

  .rec__falta { font-size: 0.76rem; color: var(--mist); white-space: nowrap; }
  .rec__falta b { color: var(--moon); }
  .rec:not(.is-tuya) { opacity: 0.66; }

  @media (max-width: 1180px) {
    .cat__l { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 760px) {
    .cat__l { grid-template-columns: 1fr; }
    .saldo { flex-direction: column; align-items: flex-start; }
  }

  /* MOVIL Y TABLET (y apaisado): la barra inferior de 64px vive abajo en toda la franja tablet
     (hasta 1280). Como esta pantalla SOBREESCRIBE el padding-bottom de .contenido (regla
     :has(.saldo) de arriba, mas especifica que la del layout), hay que devolverle aqui la
     holgura, o el pie de la ultima ficha ("Te faltan X PF" / "Abrir recompensa") queda tapado
     por la barra. Es solo holgura, no reflow: por eso llega a 1280 sin tocar el contenido. */
  @media (max-width: 1280px), (max-height: 480px) {
    .contenido:has(.saldo) { padding-bottom: calc(64px + env(safe-area-inset-bottom, 0px) + 10px); }
  }
</style>
