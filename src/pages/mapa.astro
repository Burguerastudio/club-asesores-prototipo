---
// El Mapa de la Fortaleza (P1b). El viaje: el curso entero sobre el dibujo del castro.
// No es el home (eso es El Patio); aqui se ve DONDE estas en el ciclo y que te queda.
// Sustituye a la Pagina de Viaje del sistema (Club es Ecosistema).
//
// A pantalla completa y sin marco, como la pantalla de mapa de un juego: el castro manda
// y todo lo demas flota encima. Por eso no lleva titulo ni parrafo (2026-07-17): el HUD
// ya dice quien eres y cuanto llevas, y cada senda dice su propio progreso.
import Fortaleza from '../layouts/Fortaleza.astro';
import { salas, sitiosDelMapa, sendas, sendaDelMes, intervenciones, ETIQUETA_ESTADO } from '../data/demo.js';

// Cada sitio del mapa se cruza con su sala para heredar nombre, nota y estado.
//
// La Puerta Principal se queda FUERA del mapa (Mati, 2026-07-20): no es una sala, es el
// login, y no se entra en ella desde aquí. Pintarla con su chincheta la hacía leer como un
// sitio más al que se entra, justo la confusión que el mapa tiene que evitar. El dato sigue
// en sitiosDelMapa (calibrado) por si vuelve, pero solo se pintan las cinco salas.
const sitios = sitiosDelMapa.filter((s) => s.sala).map((s) => {
  const sala = salas.find((x) => x.slug === s.slug);
  return {
    ...s,
    nombre: sala?.nombre ?? s.nombre,
    nota: sala?.nota ?? s.nota,
    estado: sala?.estado ?? s.estado,
    href: sala?.href,
  };
});

// Si una senda reclama una intervencion que no existe, el build para aqui y no en la
// cara del cliente. No es paranoia: la 12 se reclamaba de la Senda del Orden y Orden no
// la reclamaba a ella, y eso vivio en demo.js hasta que este Mapa lo destapo.
const porNumero = (n: number) => {
  const i = intervenciones.find((x) => x.n === n);
  if (!i) throw new Error(`El Mapa pide la intervención ${n} y demo.js no la tiene.`);
  return i;
};

const cierre = intervenciones.find((i) => i.senda === 'Cierre');
if (!cierre) throw new Error('El Mapa pide la intervención de Cierre (la 12, transversal) y demo.js no la tiene.');

// El progreso de cada senda sale de SUS intervenciones, no de un numero suelto que
// pudiera contradecirlas.
const sendasVivas = Object.entries(sendas).map(([clave, s]) => {
  const suyas = s.intervenciones.map(porNumero);
  return {
    clave, ...s,
    suyas,
    fortalecidas: suyas.filter((i) => i.estado === 'fortalecida').length,
    esLaDelMes: clave === sendaDelMes,
  };
});

const F_AZULEJO = 'tl-clip br-clip border';

const ETIQUETA_INTERV = {
  fortalecida: 'Fortalecida',
  activa: 'Sabotaje detectado',
  bloqueada: 'Bloqueada',
};
type EstadoSala = keyof typeof ETIQUETA_ESTADO;
type EstadoInterv = keyof typeof ETIQUETA_INTERV;

// El lienzo: la proporcion real del asset. La usa el CSS para cubrir la ventana sin
// deformar y el JS para no dejar arrastrar mas alla del borde.
const MAPA = { w: 2752, h: 1536 };
---

<Fortaleza title="El Mapa de la Fortaleza, Club de la Asesoría" activa="/mapa">
  <!-- El visor ocupa la ventana entera por debajo del HUD. El lienzo va dentro y se
       mueve; los hitos viven DENTRO del lienzo, asi que se mueven con el sin tocar
       ni una coordenada. -->
  <div class="visor" data-visor style={`--map-w:${MAPA.w}; --map-h:${MAPA.h}`}>
    <div class="lienzo" data-lienzo>
      <img
        class="lienzo__im"
        src="/assets/mapa-escenas/ui/mapa-fortaleza.webp"
        alt="El castro de la fortaleza a vista de pájaro, de noche sobre el acantilado"
        width={MAPA.w} height={MAPA.h}
        draggable="false"
      />

      <ul class="hitos">
        {sitios.map((s) => {
          const Caja = s.href ? 'a' : 'span';
          return (
            <li class="hitos__li" style={`left:${s.x}%; top:${s.y}%`}>
              <Caja
                class={`hito hito--${s.estado}${s.sala ? '' : ' hito--pieza'}`}
                data-slug={s.slug}
                href={s.href}
                aria-label={s.href ? `Entrar en ${s.nombre}: ${ETIQUETA_ESTADO[s.estado as EstadoSala]}. ${s.nota}` : `${s.nombre}: ${s.nota}`}
              >
                <!-- La chincheta: se planta ENCIMA de la puerta y la senala con su punta. -->
                <span class="hito__marca" data-augmented-ui={F_AZULEJO}>
                  <!-- Entrada lateral: la flecha cruza el umbral. Elegido por Mati el
                       2026-07-17 en /calibrar, viendolo puesto en las seis a la vez.
                       Es el GESTO de entrar, no el sitio: el arco ya lo pone el castro.
                       Dibujado aqui con el trazo de la casa (caja 24, grosor 1.6), como
                       todo: la regla del proyecto es iconografia propia, sin libreria.
                       La Puerta lleva otro, y no por capricho: no es una sala, no se
                       entra en ella, y ensenar el gesto de entrar seria mentir. Ella ES
                       una puerta, asi que lleva el portal. Y va en blanco en las salas
                       apagadas: lo apagado lo cuenta el halo, no el icono. -->
                  <svg class="hito__ico" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    {s.sala ? (
                      <>
                        <path d="M13.5 4.5H17a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-3.5" />
                        <path class="hito__flecha" d="M4.5 12h8.5m0 0-2.8-2.8M13 12l-2.8 2.8" />
                      </>
                    ) : (
                      <>
                        <path d="M6.6 20V11a5.4 5.4 0 0 1 10.8 0v9" />
                        <path d="M4.2 20h15.6" />
                        <path d="M12 20v-4.5" />
                      </>
                    )}
                  </svg>
                </span>
                <span class="hito__punta" aria-hidden="true"></span>

                <span class="hito__cartel" data-augmented-ui={F_AZULEJO}>
                  <b class="hito__n">{s.nombre}</b>
                  <span class="hito__e">{ETIQUETA_ESTADO[s.estado as EstadoSala]}</span>
                  <span class="hito__no">{s.nota}</span>
                </span>
              </Caja>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Los mandos del visor. Con teclado bastan las flechas y +/-, pero el raton
         necesita a donde ir. Van abajo a la derecha, lejos de los desplegables. -->
    <div class="mandos">
      <button class="mando" type="button" data-zoom="1" aria-label="Acercar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6v12M6 12h12" /></svg>
      </button>
      <button class="mando" type="button" data-zoom="-1" aria-label="Alejar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 12h12" /></svg>
      </button>
      <button class="mando" type="button" data-centrar aria-label="Centrar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 8.2A3.8 3.8 0 1 0 12 15.8 3.8 3.8 0 0 0 12 8.2z" />
          <path d="M12 3v2.6M12 18.4V21M3 12h2.6M18.4 12H21" />
        </svg>
      </button>
    </div>

    <!-- LAS SENDAS, en la banda de abajo. Cuatro desplegables: las tres del triskel y el
         Cierre, que no es una senda (cruza las tres) y por eso va aparte y al final. -->
    <div class="banda">
      {sendasVivas.map((s) => (
        <details class={`ruta${s.esLaDelMes ? ' is-mes' : ''}`} name="senda">
          <summary class="ruta__t" data-augmented-ui={F_AZULEJO}>
            <span class="ruta__n">{s.nombre}</span>
            <span class="ruta__p"><b>{s.fortalecidas}</b>/{s.suyas.length}</span>
            {s.esLaDelMes && <span class="ruta__mes">Este mes</span>}
            <svg class="ruta__v" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 5l4-4 4 4" /></svg>
          </summary>

          <div class="ruta__c" data-augmented-ui={F_AZULEJO}>
            <p class="ruta__f">{s.foco}</p>
            <ol class="intervs">
              {s.suyas.map((i) => {
                const Caja = i.estado === 'activa' ? 'a' : 'span';
                return (
                  <li>
                    <Caja class={`interv interv--${i.estado}`} href={i.estado === 'activa' ? '/dashboard' : undefined}>
                      <span class="interv__n" aria-hidden="true">{i.n}</span>
                      <span class="interv__d">
                        <b class="interv__t">{i.titulo}</b>
                        <span class="interv__e">{ETIQUETA_INTERV[i.estado as EstadoInterv]}</span>
                      </span>
                    </Caja>
                  </li>
                );
              })}
            </ol>
          </div>
        </details>
      ))}

      <!-- El Cierre. Mismo mueble que las sendas para que la banda lea como una sola
           cosa, pero separado por un filo: no es la cuarta senda, es la meta. -->
      <details class="ruta ruta--cierre" name="senda">
        <summary class="ruta__t" data-augmented-ui={F_AZULEJO}>
          <span class="ruta__n">Cierre del ciclo</span>
          <span class="ruta__p"><b>0</b>/1</span>
          <svg class="ruta__v" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 5l4-4 4 4" /></svg>
        </summary>
        <div class="ruta__c" data-augmented-ui={F_AZULEJO}>
          <p class="ruta__f">Transversal a las tres sendas. Se abre cuando el ciclo está listo para cerrarse.</p>
          <ol class="intervs">
            <li>
              <span class={`interv interv--${cierre.estado}`}>
                <span class="interv__n" aria-hidden="true">{cierre.n}</span>
                <span class="interv__d">
                  <b class="interv__t">{cierre.titulo}</b>
                  <span class="interv__e">{ETIQUETA_INTERV[cierre.estado as EstadoInterv]}</span>
                </span>
              </span>
            </li>
          </ol>
        </div>
      </details>
    </div>
  </div>
</Fortaleza>

<script>
  import { montarVisor } from '../scripts/visor.js';
  import { estadoDemo, estadoIntervencion } from '../scripts/demo-director.js';
  montarVisor();

  // CONMUTADOR DE DEMO. Lo global (HUD, PF, rango, barra) ya lo reescribe demo-director.js;
  // aqui se re-deriva el estado PROFUNDO propio del Mapa para el rango elegido. Solo se tocan
  // ESTADOS (clases), etiquetas de estado (diccionarios fijos) y el contador x/y de cada
  // senda. La narrativa de Sepia (las notas de cada sala, los titulos de las intervenciones)
  // NO se toca: en rangos altos una nota puede contradecir su nuevo estado, y eso es preferible
  // a inventar texto. En el rango 3 (F=4) todo esto re-deriva a lo mismo que ya pinta el build.
  (() => {
    const { r, fortalecidas: F } = estadoDemo();

    // (1) LAS SALAS del castro. Estado de cada chincheta por rango (tabla fija; en r3 coincide
    // con demo.js). Se identifica cada sitio por su data-slug, no por indice: el orden del DOM
    // no es el de la tabla. Se re-derivan la clase de estado (de ella cuelgan en CSS el halo, el
    // filo, el tinte y el color de la etiqueta) y el texto de la etiqueta. La nota se deja como
    // esta: es narrativa y describe el estado por defecto de la sala.
    const SITIOS_POR_RANGO: Record<number, Record<string, string>> = {
      1: { 'sala-mandos': 'reparacion',  'biblioteca': 'desconectada', 'torre-retos': 'desconectada', 'consejo': 'desconectada', 'mirador': 'desconectada' },
      2: { 'sala-mandos': 'fortalecida', 'biblioteca': 'reparacion',   'torre-retos': 'desconectada', 'consejo': 'desconectada', 'mirador': 'desconectada' },
      3: { 'sala-mandos': 'fortalecida', 'biblioteca': 'reparacion',   'torre-retos': 'reparacion',   'consejo': 'desconectada', 'mirador': 'desconectada' },
      4: { 'sala-mandos': 'fortalecida', 'biblioteca': 'fortalecida',  'torre-retos': 'fortalecida',  'consejo': 'reparacion',   'mirador': 'desconectada' },
      5: { 'sala-mandos': 'fortalecida', 'biblioteca': 'fortalecida',  'torre-retos': 'fortalecida',  'consejo': 'fortalecida',  'mirador': 'fortalecida' },
    };
    // Espejo de ETIQUETA_ESTADO (demo.js): la clave interna sigue siendo 'fortalecida', lo que
    // se lee es 'Activada'.
    const ETIQUETA_ESTADO: Record<string, string> = { fortalecida: 'Activada', reparacion: 'En reparación', desconectada: 'Desconectada' };
    const tabla = SITIOS_POR_RANGO[r] || SITIOS_POR_RANGO[3];
    document.querySelectorAll<HTMLElement>('.hito').forEach((hito) => {
      const slug = hito.dataset.slug;
      const estado = slug ? tabla[slug] : undefined;
      if (!estado) return; // pieza sin sala (la Puerta): no esta en la tabla, se deja como esta
      hito.classList.remove('hito--fortalecida', 'hito--reparacion', 'hito--desconectada');
      hito.classList.add('hito--' + estado);
      const et = hito.querySelector('.hito__e');
      if (et) et.textContent = ETIQUETA_ESTADO[estado];
      // El aria-label rehace SOLO su etiqueta de estado; nombre y nota se leen del propio cartel.
      if (hito.hasAttribute('aria-label')) {
        const nombre = hito.querySelector('.hito__n')?.textContent ?? '';
        const nota = hito.querySelector('.hito__no')?.textContent ?? '';
        hito.setAttribute('aria-label', `Entrar en ${nombre}: ${ETIQUETA_ESTADO[estado]}. ${nota}`);
      }
    });

    // (2) LAS SENDAS de la banda. Cada .ruta (las tres del triskel y el Cierre) lleva su lista de
    // intervenciones; el numero de cada una esta en su .interv__n. Se re-deriva el estado de cada
    // intervencion con estadoIntervencion(n, F), se cuenta cuantas quedan fortalecidas para el
    // contador x/y y se refresca su etiqueta. Se lee el numero del DOM, asi no hay que saber que
    // senda es ni repetir el reparto de intervenciones.
    const ETIQUETA_INTERV: Record<string, string> = { fortalecida: 'Fortalecida', activa: 'Sabotaje detectado', bloqueada: 'Bloqueada' };
    document.querySelectorAll('.banda .ruta').forEach((ruta) => {
      let fort = 0;
      ruta.querySelectorAll('.intervs .interv').forEach((item) => {
        const n = parseInt(item.querySelector('.interv__n')?.textContent ?? '', 10);
        const estado = estadoIntervencion(n, F);
        if (estado === 'fortalecida') fort++;
        item.classList.remove('interv--fortalecida', 'interv--activa', 'interv--bloqueada');
        item.classList.add('interv--' + estado);
        const et = item.querySelector('.interv__e');
        if (et) et.textContent = ETIQUETA_INTERV[estado];
        // Solo la activa es puerta (lleva al Patio). Si un enlace deja de ser la activa, se le
        // quita el href para que no navegue con su estado nuevo.
        if (item.tagName === 'A') {
          if (estado === 'activa') item.setAttribute('href', '/dashboard');
          else item.removeAttribute('href');
        }
      });
      const cont = ruta.querySelector('.ruta__p b');
      if (cont) cont.textContent = String(fort);
    });
  })();
</script>

<style is:global>
  /* EL VISOR A PANTALLA COMPLETA.
     El layout de Fortaleza.astro mete el contenido en una columna de 1400px con su
     margen; el mapa tiene que salirse de ahi y ocupar la ventana entera. Se rompe la
     columna con el 100vw y el desplazamiento a la mitad del ancho. */
  .contenido:has(.visor) { padding: 0; }
  .contenido > .visor {
    width: 100vw; max-width: 100vw;
    margin-left: 50%; transform: translateX(-50%);
    /* El margen negativo lo sube hasta el techo de la ventana (el HUD flota encima, no
       ocupa), asi que el alto es la ventana ENTERA. Restarle el HUD dejaba su altura de
       franja muerta justo abajo, debajo de la banda de sendas. */
    margin-top: calc(var(--alto-shell) * -1 - 26px);
    height: 100svh;
    position: relative; overflow: hidden;
    /* El cursor dice que esto se arrastra antes de que lo intentes */
    cursor: grab;
    touch-action: none;
  }
  .visor.is-agarrado { cursor: grabbing; }

  /* EL LIENZO. Guarda la proporcion del asset y se hace lo bastante grande para cubrir
     el visor: asi los hitos, que van en % sobre el, siguen cayendo donde deben pase lo
     que pase con la ventana. Lo mueve scripts/visor.js. */
  .lienzo {
    position: absolute; top: 0; left: 0;
    width: max(100%, calc(100svh * var(--map-w) / var(--map-h)));
    aspect-ratio: var(--map-w) / var(--map-h);
    transform-origin: 0 0;
    will-change: transform;
  }
  .lienzo__im { display: block; width: 100%; height: 100%; user-select: none; -webkit-user-drag: none; }

  .hitos { list-style: none; margin: 0; padding: 0; position: absolute; inset: 0; }
  .hitos__li { position: absolute; }

  /* LA CHINCHETA. El ancla es la PUERTA: la marca se planta encima y la punta la senala.
     translate(-50%, -100%) pone el pie del hito justo en la coordenada, que es lo que
     hace que apunte en vez de taparla. */
  .hito {
    position: absolute; left: 0; top: 0;
    transform: translate(-50%, -100%);
    display: flex; flex-direction: column; align-items: center;
    text-decoration: none; color: inherit;
    /* --luz es el color del estado. La usan el halo, el filo, el icono y la punta, asi
       que el estado se cambia en un sitio y baja a las cuatro piezas solo. */
    --luz: var(--aqua);
    --luz-rgb: 95, 208, 224;
    filter: drop-shadow(0 6px 12px rgba(0,0,0,0.8));
  }

  /* EL HALO. Va en el ::before del .hito y NO en la marca, por lo de siempre: la marca
     lleva augmented-ui, o sea clip-path, y el clip-path se come el box-shadow. El pulso
     de las salas en reparacion llevaba puesto desde el principio y no se habia visto
     nunca por eso mismo. Aqui .hito no va recortado, asi que el halo se ve.
     Y se anima por OPACIDAD y no por filter: animar filter re-rasteriza cada frame, que
     es lo que dio lag en el Patio (ver docs/PLAN-MEJORA.md). */
  .hito::before {
    content: ''; position: absolute; top: -7px; left: 50%; z-index: -1;
    width: 48px; height: 48px; transform: translateX(-50%);
    border-radius: 50%; pointer-events: none;
    background: radial-gradient(closest-side, rgba(var(--luz-rgb), 0.75), transparent 70%);
    filter: blur(7px);
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .hito__marca {
    --aug-tl: 7px; --aug-br: 7px;
    --aug-border-all: 1px;
    --aug-border-bg: var(--luz);
    width: 34px; height: 34px; display: grid; place-items: center;
    /* Tenido con su propia luz en vez de negro plano: la chincheta es una luz de la
       fortaleza, como los faroles del castro, no una etiqueta pegada encima. */
    background: linear-gradient(180deg, rgba(var(--luz-rgb), 0.34), rgba(9,13,20,0.94));
    color: var(--luz);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .hito__ico {
    width: 19px; height: 19px; fill: none; stroke: currentColor;
    stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round;
  }
  /* La punta: el pico que toca la puerta */
  .hito__punta { width: 2px; height: 9px; background: var(--luz); }

  /* El estado se ve en la materia, como en toda la casa: la fortalecida arde en ambar,
     la que esta en reparacion late en cian, y la desconectada esta apagada. */
  .hito--fortalecida { --luz: var(--gold); --luz-rgb: 201, 162, 75; }

  /* Apagada: es lo que significa desconectada, asi que aqui NO se sube el brillo. Si
     brillan las cinco igual, el estado deja de contar nada. */
  .hito--desconectada {
    --luz: rgba(194,205,214,0.5);
    --luz-rgb: 194, 205, 214;
  }
  .hito--desconectada::before { opacity: 0.18; }
  /* El icono va en BLANCO aunque la sala este apagada. Iba en gris y la flecha encima al
     25%, y no se veia: un icono ilegible no dice nada, ni siquiera "apagado". Lo apagado
     lo cuentan el halo (18% contra 85), el filo y el tinte del fondo, que para eso estan.
     El icono esta para leerse. */
  .hito--desconectada .hito__marca {
    background: linear-gradient(180deg, rgba(194,205,214,0.1), rgba(9,13,20,0.94));
    color: var(--bone);
  }

  .hito:hover .hito__marca, .hito:focus-visible .hito__marca {
    transform: scale(1.14);
    background: linear-gradient(180deg, rgba(var(--luz-rgb), 0.55), rgba(9,13,20,0.9));
  }
  .hito:hover::before, .hito:focus-visible::before { opacity: 1; }
  .hito--desconectada:hover::before { opacity: 0.5; }

  /* La pieza que no es sala (la Puerta) no promete clic. Su icono ya es otro (el portal,
     no el gesto de entrar), asi que aqui no hay nada que esconder. */
  .hito--pieza { cursor: default; }

  @media (prefers-reduced-motion: no-preference) {
    .hito--reparacion::before { animation: late-hito 2.8s ease-in-out infinite alternate; }
    @keyframes late-hito { from { opacity: 0.45; } to { opacity: 1; } }
  }

  /* El cartel: el nombre solo cuando lo pides. En reposo el mapa se lee como un mapa. */
  .hito__cartel {
    --aug-tl: 6px; --aug-br: 6px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.4);
    position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
    width: max-content; max-width: 210px; padding: 9px 13px;
    display: flex; flex-direction: column; gap: 3px;
    background-color: rgba(9,13,20,0.97);
    background-image: var(--grano);
    opacity: 0; visibility: hidden; pointer-events: none; z-index: 5;
    transition: opacity 0.2s ease, visibility 0.2s;
  }
  .hito:hover .hito__cartel, .hito:focus-visible .hito__cartel { opacity: 1; visibility: visible; }
  .hito__n { font-family: var(--display); font-weight: 600; font-size: 0.84rem; color: var(--bone); letter-spacing: 0.03em; }
  .hito__e { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--aqua); }
  .hito--fortalecida .hito__e { color: var(--gold); }
  .hito--desconectada .hito__e { color: var(--mist); }
  .hito__no { font-size: 0.72rem; line-height: 1.4; color: var(--moon); }

  /* LOS MANDOS DEL VISOR */
  .mandos {
