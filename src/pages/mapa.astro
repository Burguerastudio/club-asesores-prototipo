  .interv--bloqueada { opacity: 0.45; }

  /* ============================ RESPONSIVE ============================ */

  /* TABLET / ESCRITORIO PEQUENO: las cuatro sendas no caben en una fila; se reparten en dos. */
  @media (max-width: 980px) {
