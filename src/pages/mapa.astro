---
// El Mapa de la Fortaleza (P1b). El viaje: el curso entero sobre el dibujo del castro.
// No es el home (eso es El Patio); aqui se ve DONDE estas en el ciclo y que te queda.
// Sustituye a la Pagina de Viaje del sistema (Club es Ecosistema).
//
// A pantalla completa y sin marco, como la pantalla de mapa de un juego: el castro manda
// y todo lo demas flota encima. Por eso no lleva titulo ni parrafo (2026-07-17): el HUD
// ya dice quien eres y cuanto llevas, y cada senda dice su propio progreso.
import Fortaleza from '../layouts/Fortaleza.astro';
import { salas, sitiosDelMapa, sendas, sendaDelMes, intervenciones, ETIQUETA_ESTADO } from '../data/demo.js';

// Cada sitio del mapa se cruza con su sala para heredar nombre, nota y estado. La Puerta
// no es sala y trae los suyos propios.
const sitios = sitiosDelMapa.map((s) => {
  const sala = salas.find((x) => x.slug === s.slug);
  return {
    ...s,
    nombre: sala?.nombre ?? s.nombre,
    nota: sala?.nota ?? s.nota,
    estado: sala?.estado ?? s.estado,
    href: sala?.href,
  };
});

// Si una senda reclama una intervencion que no existe, el build para aqui y no en la
// cara del cliente. No es paranoia: la 12 se reclamaba de la Senda del Orden y Orden no
// la reclamaba a ella, y eso vivio en demo.js hasta que este Mapa lo destapo.
const porNumero = (n: number) => {
  const i = intervenciones.find((x) => x.n === n);
  if (!i) throw new Error(`El Mapa pide la intervención ${n} y demo.js no la tiene.`);
  return i;
};

const cierre = intervenciones.find((i) => i.senda === 'Cierre');
if (!cierre) throw new Error('El Mapa pide la intervención de Cierre (la 12, transversal) y demo.js no la tiene.');

// El progreso de cada senda sale de SUS intervenciones, no de un numero suelto que
// pudiera contradecirlas.
const sendasVivas = Object.entries(sendas).map(([clave, s]) => {
  const suyas = s.intervenciones.map(porNumero);
  return {
    clave, ...s,
    suyas,
    fortalecidas: suyas.filter((i) => i.estado === 'fortalecida').length,
    esLaDelMes: clave === sendaDelMes,
  };
});

const F_AZULEJO = 'tl-clip br-clip border';

const ETIQUETA_INTERV = {
  fortalecida: 'Fortalecida',
  activa: 'Sabotaje detectado',
  bloqueada: 'Bloqueada',
};
type EstadoSala = keyof typeof ETIQUETA_ESTADO;
type EstadoInterv = keyof typeof ETIQUETA_INTERV;

// El lienzo: la proporcion real del asset. La usa el CSS para cubrir la ventana sin
// deformar y el JS para no dejar arrastrar mas alla del borde.
const MAPA = { w: 1760, h: 983 };
---

<Fortaleza title="El Mapa de la Fortaleza, Club de la Asesoría" activa="/mapa">
  <!-- El visor ocupa la ventana entera por debajo del HUD. El lienzo va dentro y se
       mueve; los hitos viven DENTRO del lienzo, asi que se mueven con el sin tocar
       ni una coordenada. -->
  <div class="visor" data-visor style={`--map-w:${MAPA.w}; --map-h:${MAPA.h}`}>
    <div class="lienzo" data-lienzo>
      <img
        class="lienzo__im"
        src="/assets/mapa-escenas/ui/mapa-fortaleza.webp"
        alt="El castro de la fortaleza a vista de pájaro, de noche sobre el acantilado"
        width={MAPA.w} height={MAPA.h}
        draggable="false"
      />

      <ul class="hitos">
        {sitios.map((s) => {
          const Caja = s.href ? 'a' : 'span';
          return (
            <li class="hitos__li" style={`left:${s.x}%; top:${s.y}%`}>
              <Caja
                class={`hito hito--${s.estado}${s.sala ? '' : ' hito--pieza'}`}
                href={s.href}
                aria-label={s.href ? `Entrar en ${s.nombre}: ${ETIQUETA_ESTADO[s.estado as EstadoSala]}. ${s.nota}` : `${s.nombre}: ${s.nota}`}
              >
                <!-- La chincheta: se planta ENCIMA de la puerta y la senala con su punta. -->
                <span class="hito__marca" data-augmented-ui={F_AZULEJO}>
                  <!-- Entrada lateral: la flecha cruza el umbral. Elegido por Mati el
                       2026-07-17 en /calibrar, viendolo puesto en las seis a la vez.
                       Es el GESTO de entrar, no el sitio: el arco ya lo pone el castro.
                       Dibujado aqui con el trazo de la casa (caja 24, grosor 1.6), como
                       todo: la regla del proyecto es iconografia propia, sin libreria.
                       La Puerta lleva otro, y no por capricho: no es una sala, no se
                       entra en ella, y ensenar el gesto de entrar seria mentir. Ella ES
                       una puerta, asi que lleva el portal. -->
                  <svg class="hito__ico" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    {s.sala ? (
                      <>
                        <path d="M13.5 4.5H17a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2h-3.5" />
                        <path class="hito__flecha" d="M4.5 12h8.5m0 0-2.8-2.8M13 12l-2.8 2.8" />
                      </>
                    ) : (
                      <>
                        <path d="M6.6 20V11a5.4 5.4 0 0 1 10.8 0v9" />
                        <path d="M4.2 20h15.6" />
                        <path d="M12 20v-4.5" />
                      </>
                    )}
                  </svg>
                </span>
                <span class="hito__punta" aria-hidden="true"></span>

                <span class="hito__cartel" data-augmented-ui={F_AZULEJO}>
                  <b class="hito__n">{s.nombre}</b>
                  <span class="hito__e">{ETIQUETA_ESTADO[s.estado as EstadoSala]}</span>
                  <span class="hito__no">{s.nota}</span>
                </span>
              </Caja>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- Los mandos del visor. Con teclado bastan las flechas y +/-, pero el raton
         necesita a donde ir. Van abajo a la derecha, lejos de los desplegables. -->
    <div class="mandos">
      <button class="mando" type="button" data-zoom="1" aria-label="Acercar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 6v12M6 12h12" /></svg>
      </button>
      <button class="mando" type="button" data-zoom="-1" aria-label="Alejar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 12h12" /></svg>
      </button>
      <button class="mando" type="button" data-centrar aria-label="Centrar el mapa">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 8.2A3.8 3.8 0 1 0 12 15.8 3.8 3.8 0 0 0 12 8.2z" />
          <path d="M12 3v2.6M12 18.4V21M3 12h2.6M18.4 12H21" />
        </svg>
      </button>
    </div>

    <!-- LAS SENDAS, en la banda de abajo. Cuatro desplegables: las tres del triskel y el
         Cierre, que no es una senda (cruza las tres) y por eso va aparte y al final. -->
    <div class="banda">
      {sendasVivas.map((s) => (
        <details class={`ruta${s.esLaDelMes ? ' is-mes' : ''}`} name="senda">
          <summary class="ruta__t" data-augmented-ui={F_AZULEJO}>
            <span class="ruta__n">{s.nombre}</span>
            <span class="ruta__p"><b>{s.fortalecidas}</b>/{s.suyas.length}</span>
            {s.esLaDelMes && <span class="ruta__mes">Este mes</span>}
            <svg class="ruta__v" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 5l4-4 4 4" /></svg>
          </summary>

          <div class="ruta__c" data-augmented-ui={F_AZULEJO}>
            <p class="ruta__f">{s.foco}</p>
            <ol class="intervs">
              {s.suyas.map((i) => {
                const Caja = i.estado === 'activa' ? 'a' : 'span';
                return (
                  <li>
                    <Caja class={`interv interv--${i.estado}`} href={i.estado === 'activa' ? '/intervencion' : undefined}>
                      <span class="interv__n" aria-hidden="true">{i.n}</span>
                      <span class="interv__d">
                        <b class="interv__t">{i.titulo}</b>
                        <span class="interv__e">{ETIQUETA_INTERV[i.estado as EstadoInterv]}</span>
                      </span>
                    </Caja>
                  </li>
                );
              })}
            </ol>
          </div>
        </details>
      ))}

      <!-- El Cierre. Mismo mueble que las sendas para que la banda lea como una sola
           cosa, pero separado por un filo: no es la cuarta senda, es la meta. -->
      <details class="ruta ruta--cierre" name="senda">
        <summary class="ruta__t" data-augmented-ui={F_AZULEJO}>
          <span class="ruta__n">Cierre del ciclo</span>
          <span class="ruta__p"><b>0</b>/1</span>
          <svg class="ruta__v" viewBox="0 0 10 6" aria-hidden="true"><path d="M1 5l4-4 4 4" /></svg>
        </summary>
        <div class="ruta__c" data-augmented-ui={F_AZULEJO}>
          <p class="ruta__f">Transversal a las tres sendas. Se abre cuando el ciclo está listo para cerrarse.</p>
          <ol class="intervs">
            <li>
              <span class={`interv interv--${cierre.estado}`}>
                <span class="interv__n" aria-hidden="true">{cierre.n}</span>
                <span class="interv__d">
                  <b class="interv__t">{cierre.titulo}</b>
                  <span class="interv__e">{ETIQUETA_INTERV[cierre.estado as EstadoInterv]}</span>
                </span>
              </span>
            </li>
          </ol>
        </div>
      </details>
    </div>
  </div>
</Fortaleza>

<script>
  import { montarVisor } from '../scripts/visor.js';
  montarVisor();
</script>

<style is:global>
  /* EL VISOR A PANTALLA COMPLETA.
     El layout de Fortaleza.astro mete el contenido en una columna de 1400px con su
     margen; el mapa tiene que salirse de ahi y ocupar la ventana entera. Se rompe la
     columna con el 100vw y el desplazamiento a la mitad del ancho. */
  .contenido:has(.visor) { padding: 0; }
  .contenido > .visor {
    width: 100vw; max-width: 100vw;
    margin-left: 50%; transform: translateX(-50%);
    /* El margen negativo lo sube hasta el techo de la ventana (el HUD flota encima, no
       ocupa), asi que el alto es la ventana ENTERA. Restarle el HUD dejaba su altura de
       franja muerta justo abajo, debajo de la banda de sendas. */
    margin-top: calc(var(--alto-shell) * -1 - 26px);
    height: 100svh;
    position: relative; overflow: hidden;
    /* El cursor dice que esto se arrastra antes de que lo intentes */
    cursor: grab;
    touch-action: none;
  }
  .visor.is-agarrado { cursor: grabbing; }

  /* EL LIENZO. Guarda la proporcion del asset y se hace lo bastante grande para cubrir
     el visor: asi los hitos, que van en % sobre el, siguen cayendo donde deben pase lo
     que pase con la ventana. Lo mueve scripts/visor.js. */
  .lienzo {
    position: absolute; top: 0; left: 0;
    width: max(100%, calc(100svh * var(--map-w) / var(--map-h)));
    aspect-ratio: var(--map-w) / var(--map-h);
    transform-origin: 0 0;
    will-change: transform;
  }
  .lienzo__im { display: block; width: 100%; height: 100%; user-select: none; -webkit-user-drag: none; }

  .hitos { list-style: none; margin: 0; padding: 0; position: absolute; inset: 0; }
  .hitos__li { position: absolute; }

  /* LA CHINCHETA. El ancla es la PUERTA: la marca se planta encima y la punta la senala.
     translate(-50%, -100%) pone el pie del hito justo en la coordenada, que es lo que
     hace que apunte en vez de taparla. */
  .hito {
    position: absolute; left: 0; top: 0;
    transform: translate(-50%, -100%);
    display: flex; flex-direction: column; align-items: center;
    text-decoration: none; color: inherit;
    filter: drop-shadow(0 6px 12px rgba(0,0,0,0.75));
  }
  .hito__marca {
    --aug-tl: 7px; --aug-br: 7px;
    --aug-border-all: 1px;
    --aug-border-bg: var(--aqua);
    width: 34px; height: 34px; display: grid; place-items: center;
    background: linear-gradient(180deg, rgba(20,32,46,0.97), rgba(9,13,20,0.97));
    color: var(--aqua);
    transition: transform 0.2s ease, background 0.2s ease;
  }
  .hito__ico { width: 19px; height: 19px; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }
  /* La punta: el pico que toca la puerta. Con el mismo filo que la marca. */
  .hito__punta {
    width: 2px; height: 9px; background: var(--aqua); opacity: 0.85;
  }

  /* El estado se ve en la materia, como en toda la casa: la sala viva en ambar, la que
     esta en reparacion en cian, y la desconectada apagada y en gris. */
  .hito--fortalecida .hito__marca { --aug-border-bg: var(--amber); color: var(--amber); }
  .hito--fortalecida .hito__punta { background: var(--amber); }
  .hito--desconectada .hito__marca { --aug-border-bg: rgba(194,205,214,0.45); color: var(--mist); }
  .hito--desconectada .hito__punta { background: rgba(194,205,214,0.45); }
  /* La desconectada no ensena la flecha: por ahi todavia no se entra de verdad */
  .hito--desconectada .hito__flecha { opacity: 0.25; }

  .hito:hover .hito__marca, .hito:focus-visible .hito__marca { transform: scale(1.14); background: linear-gradient(180deg, rgba(63,169,201,0.3), rgba(9,13,20,0.97)); }
  /* La pieza que no es sala (la Puerta) no promete clic. Su icono ya es otro (el portal,
     no el gesto de entrar), asi que aqui no hay nada que esconder. */
  .hito--pieza { cursor: default; }

  @media (prefers-reduced-motion: no-preference) {
    .hito--reparacion .hito__marca { animation: late-hito 2.8s ease-in-out infinite alternate; }
    @keyframes late-hito { from { box-shadow: 0 0 0 rgba(95,208,224,0); } to { box-shadow: 0 0 14px rgba(95,208,224,0.55); } }
  }

  /* El cartel: el nombre solo cuando lo pides. En reposo el mapa se lee como un mapa. */
  .hito__cartel {
    --aug-tl: 6px; --aug-br: 6px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.4);
    position: absolute; bottom: calc(100% + 8px); left: 50%; transform: translateX(-50%);
    width: max-content; max-width: 210px; padding: 9px 13px;
    display: flex; flex-direction: column; gap: 3px;
    background-color: rgba(9,13,20,0.97);
    background-image: var(--grano);
    opacity: 0; visibility: hidden; pointer-events: none; z-index: 5;
    transition: opacity 0.2s ease, visibility 0.2s;
  }
  .hito:hover .hito__cartel, .hito:focus-visible .hito__cartel { opacity: 1; visibility: visible; }
  .hito__n { font-family: var(--display); font-weight: 600; font-size: 0.84rem; color: var(--bone); letter-spacing: 0.03em; }
  .hito__e { font-size: 0.64rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--aqua); }
  .hito--fortalecida .hito__e { color: var(--amber); }
  .hito--desconectada .hito__e { color: var(--mist); }
  .hito__no { font-size: 0.72rem; line-height: 1.4; color: var(--moon); }

  /* LOS MANDOS DEL VISOR */
  .mandos {
    position: absolute; right: clamp(14px, 2vw, 26px); bottom: clamp(90px, 11vh, 120px);
    z-index: 6; display: flex; flex-direction: column; gap: 6px;
  }
  .mando {
    --aug-tl: 6px; --aug-br: 6px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.3);
    width: 34px; height: 34px; display: grid; place-items: center;
    padding: 0; border: 0; color: var(--moon);
    background: rgba(9,13,20,0.86);
    transition: color 0.2s ease, background 0.2s ease;
  }
  .mando:hover { color: var(--bone); background: rgba(63,169,201,0.28); }
  .mando svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round; }

  /* LA BANDA DE SENDAS. Flota sobre el mapa, pegada abajo. */
  .banda {
    position: absolute; left: 0; right: 0; bottom: 0; z-index: 7;
    display: flex; align-items: flex-end; gap: 8px;
    padding: 0 clamp(14px, 3vw, 32px) clamp(14px, 2vh, 22px);
    /* El velo que despega la banda del mapa sin ponerle un canto */
    background: linear-gradient(to top, rgba(9,13,20,0.9) 0%, rgba(9,13,20,0.5) 55%, transparent 100%);
    padding-top: clamp(40px, 7vh, 80px);
    pointer-events: none;
  }
  .banda > * { pointer-events: auto; }

  .ruta { flex: 1 1 0; min-width: 0; max-width: 300px; }
  /* El Cierre no es la cuarta senda: se separa con un filo y no estira como ellas */
  .ruta--cierre { flex: 0 0 auto; max-width: 210px; margin-left: auto; }

  .ruta__t {
    --aug-tl: 8px; --aug-br: 8px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.26);
    list-style: none; cursor: pointer;
    display: flex; align-items: center; gap: 9px;
    padding: 11px 14px;
    background: rgba(9,13,20,0.88);
    transition: background 0.2s ease;
  }
  .ruta__t::-webkit-details-marker { display: none; }
  .ruta__t:hover { background: rgba(63,169,201,0.22); }
  .ruta[open] > .ruta__t { --aug-border-bg: var(--cyan); background: rgba(63,169,201,0.2); }
  .ruta__n { font-family: var(--display); font-size: 0.86rem; font-weight: 600; color: var(--bone); letter-spacing: 0.03em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .ruta__p { margin-left: auto; font-size: 0.76rem; color: var(--mist); white-space: nowrap; }
  .ruta__p b { color: var(--aqua); }
  .ruta__mes { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--amber); white-space: nowrap; }
  .ruta__v { width: 10px; height: 6px; flex: none; fill: none; stroke: var(--mist); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.22s ease; }
  .ruta[open] .ruta__v { transform: rotate(180deg); stroke: var(--aqua); }

  .ruta__c {
    --aug-tl: 8px; --aug-br: 8px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(63,169,201,0.34);
    margin-bottom: 7px; padding: 13px;
    background-color: rgba(9,13,20,0.97);
    background-image: var(--grano);
  }
  /* El panel abre HACIA ARRIBA: la banda vive pegada al borde de abajo, y hacia abajo
     no hay sitio. El details ordena summary y panel al reves con el column-reverse. */
  .ruta { display: flex; flex-direction: column-reverse; }
  .ruta__f { margin: 0 0 11px; font-size: 0.72rem; line-height: 1.4; color: var(--mist); }

  .intervs { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .interv {
    display: grid; grid-template-columns: 22px 1fr; align-items: center; gap: 10px;
    padding: 7px 9px; text-decoration: none;
    border-left: 2px solid rgba(194,205,214,0.2);
    transition: background 0.2s ease;
  }
  .interv__n { font-family: var(--display); font-size: 0.86rem; color: var(--mist); text-align: center; }
  .interv__d { display: flex; flex-direction: column; gap: 1px; min-width: 0; }
  .interv__t { font-size: 0.76rem; font-weight: 600; color: var(--moon); line-height: 1.25; }
  .interv__e { font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--mist); }

  .interv--fortalecida { border-left-color: var(--amber); }
  .interv--fortalecida .interv__n, .interv--fortalecida .interv__e { color: var(--amber); }
  .interv--fortalecida .interv__t { color: var(--bone); }

  /* La activa es la unica que es puerta: las otras son estado y no prometen clic */
  .interv--activa { border-left-color: var(--cyan); background: rgba(63,169,201,0.16); }
  .interv--activa .interv__t { color: var(--bone); }
  .interv--activa .interv__n, .interv--activa .interv__e { color: var(--aqua); }
  .interv--activa:hover { background: rgba(63,169,201,0.28); }

  /* Bloqueada: no se anuncia con un cartel, se ve apagada */
  .interv--bloqueada { opacity: 0.45; }

  @media (max-width: 980px) {
    .banda { flex-wrap: wrap; }
    .ruta, .ruta--cierre { flex: 1 1 44%; max-width: none; margin-left: 0; }
  }
</style>
