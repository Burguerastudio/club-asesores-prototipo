  @media (max-width: 860px), (max-height: 480px) {
    .banda {
      bottom: calc(64px + env(safe-area-inset-bottom, 0px));
      gap: 7px;
      /* El hueco de la izquierda es para la pestana Demo: ningun rotulo cae detras de ella. */
      padding-left: 58px;
      padding-right: clamp(12px, 3vw, 20px);
      padding-top: clamp(34px, 6vh, 60px);
      padding-bottom: 6px;
    }
    /* La ranura estrecha no da para nombre y contador en la misma linea sin comerse el
       nombre. Se parte en dos: el titulo entero arriba (Cinzel a dos lineas si hace falta,
       sin puntos suspensivos) y debajo el contador, la marca del mes y la flecha. */
    .ruta__t { flex-wrap: wrap; row-gap: 5px; padding: 10px 12px; }
    .ruta__n { flex: 1 1 100%; white-space: normal; line-height: 1.15; overflow: visible; }
    .ruta__p { margin-left: 0; }
    .ruta__v { margin-left: auto; }
    /* Un panel abierto no debe crecer mas que la ventana: si no cabe, rueda por dentro. */
    .ruta__c { max-height: 46svh; overflow-y: auto; }
    /* Los mandos se van al centro derecha: la esquina de abajo es de la banda. */
    .mandos {
      top: 50%; bottom: auto; transform: translateY(-50%);
      right: clamp(8px, 2.5vw, 14px);
    }
    /* Objetivo tactil comodo para acercar, alejar y centrar. */
    .mando { width: 40px; height: 40px; }
    .mando svg { width: 19px; height: 19px; }
  }

  /* APAISADO (poca altura): sobra ancho pero falta alto, asi que las cuatro sendas vuelven a
     una sola fila para no comerse el mapa, y el nombre cabe entero de nuevo. */
  @media (max-height: 480px) {
    .banda { flex-wrap: nowrap; padding-top: clamp(26px, 6vh, 44px); }
