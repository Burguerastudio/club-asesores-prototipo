  .ruta__v { width: 10px; height: 6px; flex: none; fill: none; stroke: var(--mist); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.22s ease; }
  .ruta[open] .ruta__v { transform: rotate(180deg); stroke: var(--aqua); }

