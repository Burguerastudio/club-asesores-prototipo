  /* Cinzel renderiza en versalitas (mas anchas que la sans): a 0.86rem "Senda del Crecimiento"
     se cortaba en la banda. 0.78 la deja entrar entera manteniendo el titular en Cinzel. */
  .ruta__n { font-family: var(--display); font-size: 0.78rem; font-weight: 600; color: var(--bone); letter-spacing: 0.02em; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
