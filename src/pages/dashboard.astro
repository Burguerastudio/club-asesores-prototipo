---
// El Patio (Dashboard). El parte de tu fortaleza: de un vistazo, qué toca hoy y cómo vas.
// Fundido el 2026-07-21: absorbe la página de intervención (P7) y suelta los azulejos de
// salas (los cubre el Mapa). Queda COHERENTE en dos bloques:
//   1. La intervención del mes: el problema (El Rebelde), los tres pasos como PUERTAS a su
//      sala (la clase→Biblioteca, el reto→Torre), la recompensa que se enciende sola, y Nara
//      guiando ahí mismo el siguiente paso. Sin botón suelto: el paso que toca ES la acción.
//   2. Tu avance: rango, el año en tramos y tus últimos logros, rotulados.
import Fortaleza from '../layouts/Fortaleza.astro';
import Motas from '../components/Motas.astro';
import { asesora, activa, intervenciones, logrosRecientes } from '../data/demo.js';

// La habilidad que forja esta intervención (junto con la insignia, la recompensa completa).
const habilidadMes = intervenciones.find((i) => i.n === activa.n)?.habilidad?.nombre;

// Cada paso, dónde se hace. Los dos primeros son PUERTAS (llevan a su sala); el tercero no
// es destino, es la recompensa automática. Nombre exacto del tier -> su puerta.
const PASOS: Record<string, { href: string | null; ir: string }> = {
  'Progresión': { href: '/biblioteca', ir: 'Ver la clase en la Biblioteca' },
  'Reto de Torre': { href: '/torre-retos', ir: 'Encender la señal en la Torre' },
  'Evolución': { href: null, ir: '' },
};

// Nara guía el paso que toca, aquí mismo (ya no cuelga sola abajo).
const guiaNara = 'Ya bajaste el saber a tu despacho. Enciende ahora la señal en la Torre y esta grieta quedará reparada.';

// La barra de rango: un tramo por intervención, con su estado real.
const tramos = intervenciones.map((i) => i.estado);

// --- EL ENDGAME: la cara COMPLETADA de El Patio (12/12). No es ruta aparte, es un ESTADO:
// cuando cierras el ciclo, el Patio deja de mostrar "qué toca hoy" y muestra el cierre. Lo
// enseñará el conmutador de demo; mientras no exista, con ?fin en la URL. Usa el mapa de la
// fortaleza en alta (el Mirador solo hay en tamaño azulejo: pedir -fondo a Mati si se quiere
// su vista literal; el mapa completo encaja con "mapa iluminado, piezas colocadas", P9).
const sello = (n: number) => `/assets/emblemas-insignias/ui/insignias-intervencion/sellos/insignia-i${String(n).padStart(2, '0')}-sello.webp`;
const sellosFin = intervenciones.map((i) => ({ n: i.n, titulo: i.titulo, sinopsis: i.sinopsis, img: sello(i.n) }));
const rangoFinal = 'Asesora Fortalecida';
const naraFin = 'Doce grietas, reparadas. Tu fortaleza ya se sostiene sola. Desde aquí se ven las que vendrán: el segundo ciclo asoma en el horizonte.';

const F_MAYOR = 'tl-2-clip-y tr-2-clip-y bl-2-clip-y br-2-clip-y border';
const F_RANURA = 'tl-clip tr-clip bl-clip br-clip border';
---

<Fortaleza title="El Patio, Club de la Asesoría" activa="/dashboard">
  <!-- El estado completado (Endgame). Lo dispara el conmutador de demo en rango 5 (leido de
       localStorage aqui, antes del paint, para que no parpadee); tambien con ?fin o #fin en la
       URL como atajo. En rango 5 El Patio muestra el cierre del ciclo en vez del mes. -->
  <script is:inline>
    (() => {
      let r = 3; try { r = JSON.parse(localStorage.getItem('fortaleza-demo') || '{}').rango || 3; } catch {}
      if (r === 5 || location.search.includes('fin') || location.hash === '#fin')
        document.documentElement.classList.add('es-fin');
    })();
  </script>

  <header class="cab">
    <h1 class="display cab__t"><span data-saludo>Buenos días</span>, <span data-yo-nombre>{asesora.nombre}</span></h1>
    <script is:inline>
      (() => {
        const h = new Date().getHours();
        const s = h >= 6 && h < 13 ? 'Buenos días' : h >= 13 && h < 20 ? 'Buenas tardes' : 'Buenas noches';
        document.querySelector('[data-saludo]').textContent = s;
      })();
    </script>
  </header>

  <div class="grid">
    <!-- 1. LA INTERVENCIÓN DEL MES. El foco: qué toca hoy, de principio a fin. -->
    <div class="placa-caja m-activa-caja">
      <Motas base={9} refuerzo={7} />

      <section class="placa forma-mayor m-activa" aria-label="La intervención de este mes" data-augmented-ui={F_MAYOR}>
        <div class="placa__cab">
          <p class="rotulo">Intervención {activa.n} de 12, Senda del {activa.senda}</p>
        </div>

        <div class="m-activa__cuerpo">
          <!-- IZQUIERDA: el relato. El problema (El Rebelde) y la guía (Nara). -->
          <div class="m-activa__txt">
            <h2 class="display m-activa__t">{activa.titulo}</h2>
            <p class="m-activa__sab"><b>Sabotaje detectado.</b> {activa.sabotaje}</p>

            <div class="m-activa__guia">
              <img class="m-activa__nara" src="/assets/retratos/ui/nara.webp" alt="Nara" width="256" height="256" />
              <p class="m-activa__guia-txt">{guiaNara}<span class="m-activa__guia-firma">Nara, guardiana de la fortaleza</span></p>
            </div>
          </div>

          <!-- DERECHA: los tres pasos. Cada acción es una PUERTA a su sala; la recompensa
               se enciende sola. La flecha marca lo que se pulsa. -->
          <ol class="pasos" aria-label="Los tres pasos de la intervención">
            {activa.tiers.map((t) => {
              const paso = PASOS[t.nombre] ?? { href: null, ir: '' };
              const estado = t.hecho ? 'hecho' : t.toca ? 'toca' : 'premio';
              const esPuerta = !!paso.href;
              const Caja = esPuerta ? 'a' : 'div';
              return (
                <li class="paso-li">
                  <Caja class={`paso paso--${estado}`} href={esPuerta ? paso.href : undefined} data-augmented-ui={F_RANURA}>
                    <span class="paso__nodo" aria-hidden="true">
                      <img class="paso__im" src={t.img} alt="" width="256" height="256" />
                      {estado === 'hecho' && <svg class="paso__mk paso__mk--ok" viewBox="0 0 24 24"><path d="M5 13l4 4 10-10" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>}
                    </span>

                    <span class="paso__d">
                      <span class="paso__cab">
                        <b class="paso__n">{t.nombre}</b>
                        <span class="paso__pf">+{t.pf} PF</span>
                      </span>

                      {estado === 'premio' ? (
                        <>
                          <span class="paso__rec">Insignia <b>{t.insignia}</b> · Habilidad <b>{habilidadMes}</b></span>
                          <span class="paso__nota">Se enciende sola al completar el reto</span>
                        </>
                      ) : (
                        <>
                          <span class="paso__q">{t.que}</span>
                          <span class="paso__ir">{paso.ir}<svg class="paso__flecha" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 12h13M13 6l6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
                        </>
                      )}
                    </span>

                    <span class="sr-only">{estado === 'hecho' ? 'hecho' : estado === 'toca' ? 'lo que toca ahora' : 'recompensa, automática'}</span>
                  </Caja>
                </li>
              );
            })}
          </ol>
        </div>
      </section>

      <img class="m-activa__reb" src="/assets/personajes/ui/rebelde.webp" alt="El Rebelde" width="292" height="649" />
    </div>

    <!-- 2. TU AVANCE. Rango y año a un lado, tus últimos logros al otro, con su rótulo. -->
    <section class="mod m-ficha" aria-label="Tu avance">
      <div class="m-ficha__c">
        <span class="figura m-ficha__figwrap">
          <img class="m-ficha__av" src={asesora.avatar} alt="" aria-hidden="true" width="433" height="580" data-yo-cara />
        </span>

        <div class="m-ficha__prog">
          <h2 class="display m-ficha__r" data-yo-rango>{asesora.rango}</h2>
          <p class="m-ficha__sub"><span data-yo-fort>{asesora.fortalecidas}</span> de {asesora.totalIntervenciones} intervenciones fortalecidas</p>
          <div class="barra" aria-hidden="true">
            {tramos.map((e) => <span class={e === 'fortalecida' ? 'is-on' : e === 'activa' ? 'is-toca' : ''}></span>)}
          </div>
          <p class="m-ficha__falta">Te faltan <span data-yo-faltan>{asesora.faltanParaSiguiente}</span> para <span data-yo-rango-sig>{asesora.rangoSiguiente}</span></p>
        </div>

        <div class="m-ficha__logros">
          <p class="m-ficha__logros-k">Últimos logros</p>
          <ul class="logros">
            {logrosRecientes.map((l) => (
              <li class="logro" tabindex="0">
                <img src={l.img} alt="" width="256" height="256" loading="lazy" decoding="async" />
                <b>{l.nombre}</b>
                <span class="pista" role="tooltip" data-augmented-ui="tl-clip br-clip border">{l.pie}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- EL ENDGAME. Solo visible en estado completado (.es-fin). El ciclo cerrado: el mapa
         iluminado de fondo, las doce grietas reparadas y Nara cerrando de cara al horizonte. -->
    <section class="m-fin" aria-label="Fin del primer ciclo">
      <div class="m-fin__escena" aria-hidden="true">
        <img class="m-fin__im" src="/assets/mapa-escenas/ui/mapa-fortaleza.webp" alt="" width="2752" height="1536" />
      </div>
      <div class="m-fin__velo" aria-hidden="true"></div>

      <!-- El cuerpo: Nara de pie mirando su fortaleza, y el mensaje del cierre a su lado. -->
      <div class="m-fin__cuerpo">
        <aside class="m-fin__nara-fig" aria-hidden="true">
          <span class="figura figura--luz">
            <img src="/assets/personajes/ui/nara.webp" alt="" width="184" height="580" loading="lazy" />
            <span class="aura"></span>
          </span>
        </aside>

        <div class="m-fin__txt">
          <span class="m-fin__k">Primer ciclo completado · {rangoFinal}</span>
          <h2 class="display m-fin__t">Tu fortaleza ya está en marcha.</h2>
          <p class="m-fin__sub">Ahora empieza la responsabilidad de seguir fortaleciéndola.</p>
          <p class="m-fin__nara cita">{naraFin}<span class="m-fin__firma">Nara, guardiana de la fortaleza</span></p>
        </div>
      </div>

      <!-- El friso: las doce insignias en oro, repartidas a lo ancho como un muro de sellos. -->
      <div class="m-fin__friso">
        <p class="m-fin__friso-k">Las doce grietas, reparadas</p>
        <ul class="fin-sellos">
          {sellosFin.map((s) => (
            <li class="fin-sello" tabindex="0">
              <img src={s.img} alt={`${s.n}. ${s.titulo}`} width="256" height="256" loading="lazy" />
              <span class="pista" role="tooltip" data-augmented-ui="tl-clip br-clip border"><b class="fin-sello__t">{s.titulo}</b><span class="fin-sello__q">{s.sinopsis}</span></span>
            </li>
          ))}
        </ul>
      </div>
    </section>
  </div>
</Fortaleza>

<script>
  import gsap from 'gsap';
  import { sonar } from '../scripts/audio.js';
  import { estadoDemo } from '../scripts/demo-director.js';

  // La llegada al Patio: timeline sobria que ordena la lectura (saludo, intervención con el
  // Rebelde entrando el último, tu avance) y luego la ceremonia de datos (la barra se
  // enciende en cascada y los logros asientan).
  const motionOk = matchMedia('(prefers-reduced-motion: no-preference)').matches;
  const primeraVez = !sessionStorage.getItem('patio-visto');

  // El estado real lo manda el conmutador de demo (fortalecidas 0..12), no el DOM inicial:
  // si la barra se lee del DOM, la ceremonia repinta el estado por defecto encima del que el
  // director acaba de aplicar. Asi la cascada enciende SIEMPRE los tramos del rango elegido.
  const demo = estadoDemo();
  const spansBarra = [...document.querySelectorAll('.barra span')];
  const estadosBarra: string[] = spansBarra.map((_, i) =>
    i < demo.fortalecidas ? 'is-on' : (i === demo.fortalecidas && demo.r !== 5) ? 'is-toca' : '');
  const nodoPF = document.querySelector('[data-yo-pf]');
  const objetivoPF = demo.pf;

  if (motionOk && primeraVez) {
    spansBarra.forEach((s) => s.classList.remove('is-on', 'is-toca'));
    if (nodoPF) nodoPF.textContent = '0';
  }

  function ceremonia() {
    if (!primeraVez) return;
    sessionStorage.setItem('patio-visto', '1');

    spansBarra.forEach((s, i) => {
      const clase = estadosBarra[i];
      if (!clase) return;
      setTimeout(() => {
        s.classList.add(clase, 'is-chispa');
        s.addEventListener('animationend', () => s.classList.remove('is-chispa'), { once: true });
      }, i * 75);
    });

    if (nodoPF && objetivoPF > 0) {
      const cuenta = { v: 0 };
      gsap.to(cuenta, {
        v: objetivoPF,
        duration: 0.7,
        ease: 'power1.out',
        onUpdate: () => { nodoPF.textContent = Math.round(cuenta.v).toLocaleString('es-ES'); },
        onComplete: () => sonar('click', 0.22),
      });
    }

    gsap.fromTo('.logro', { scale: 0.94, opacity: 0.55 }, { scale: 1, opacity: 1, duration: 0.32, stagger: 0.09, ease: 'power2.out', delay: 0.45 });
  }

  const mm = gsap.matchMedia();
  mm.add('(prefers-reduced-motion: no-preference)', () => {
    const tl = gsap.timeline({ defaults: { ease: 'power2.out' } });
    tl.fromTo('.cab', { y: 14, opacity: 0 }, { y: 0, opacity: 1, duration: 0.55 }, 0)
      .fromTo('.m-activa-caja', { y: 18, opacity: 0 }, { y: 0, opacity: 1, duration: 0.6 }, 0.12)
      .fromTo('.m-activa__reb', { x: 12, opacity: 0 }, { x: 0, opacity: 1, duration: 0.5 }, 0.35)
      .fromTo('.m-ficha', { y: 16, opacity: 0 }, { y: 0, opacity: 1, duration: 0.55 }, 0.3)
      .then(ceremonia);
  });
</script>

<style is:global>
  .entra .cab,
  .entra .m-activa-caja,
  .entra .m-ficha {
    opacity: 0;
    animation: destape 0.01s linear 1.6s forwards;
  }
  @keyframes destape { to { opacity: 1; } }

  .barra span.is-chispa { animation: chispa 0.4s ease-out; }
  @keyframes chispa { from { filter: brightness(2.2); } to { filter: brightness(1); } }

  .cab { margin-bottom: clamp(14px, 2vh, 22px); }
  .cab__t { margin: 0; font-size: clamp(1.4rem, 1.9vw, 1.8rem); }

  .grid { display: grid; grid-template-columns: repeat(12, 1fr); gap: clamp(22px, 2.4vw, 40px) clamp(20px, 2vw, 34px); }
  .mod { position: relative; display: flex; flex-direction: column; }

  /* ---- 1. LA INTERVENCIÓN ---- */
  .m-activa-caja { grid-column: span 12; }
  .m-activa {
    height: 100%; display: flex; flex-direction: column;
    --aug-border-bg: linear-gradient(150deg,
      rgba(242,196,113,0.62) 0%, rgba(232,169,63,0.3) 26%,
      rgba(58,70,84,0.36) 54%, rgba(201,162,75,0.4) 100%);
  }
  .m-activa .placa__cab { position: relative; z-index: 1; background: linear-gradient(180deg, rgba(232,169,63,0.14), rgba(9,13,20,0)); border-bottom-color: rgba(232,169,63,0.22); }
  .m-activa .placa__cab .rotulo { color: var(--amber-2); }

  .m-activa__cuerpo {
    position: relative; z-index: 1; flex: 1; min-width: 0;
    display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    gap: clamp(26px, 3.4vw, 56px);
    padding-right: clamp(104px, 10.5vw, 168px);
  }
  .m-activa__txt { display: flex; flex-direction: column; align-items: flex-start; min-width: 0; }
  .m-activa__t { margin: 0; font-size: clamp(1.8rem, 2.6vw, 2.4rem); }
  .m-activa__sab { margin: 0.7rem 0 0; font-size: 0.92rem; line-height: 1.55; color: var(--silver); max-width: 54ch; }
  .m-activa__sab b { color: var(--amber); }

  /* Nara guía, aquí mismo: retrato en moneda + su voz, firmada. Anclada abajo del relato. */
  .m-activa__guia { display: flex; align-items: center; gap: 13px; margin-top: auto; padding-top: clamp(16px, 2.2vh, 24px); }
  .m-activa__nara {
    flex: none; width: clamp(44px, 4vw, 56px); height: clamp(44px, 4vw, 56px);
    border-radius: 50%; object-fit: cover; object-position: center top;
    box-shadow: inset 0 0 0 1px rgba(95,208,224,0.4), 0 0 18px rgba(63,169,201,0.25);
  }
  .m-activa__guia-txt { margin: 0; font-family: var(--italic, serif); font-style: italic; font-size: 0.9rem; line-height: 1.5; color: var(--moon); }
  .m-activa__guia-firma { display: block; margin-top: 4px; font-style: normal; font-size: 0.68rem; letter-spacing: 0.05em; color: var(--mist); }

  .m-activa__reb {
    position: absolute; z-index: 5; right: -20px; bottom: -18px;
    width: clamp(104px, 9.8vw, 146px); height: auto; pointer-events: none;
    filter: drop-shadow(-16px 16px 26px rgba(0,0,0,0.9));
  }

  /* Los tres pasos. Puerta = enlace con flecha; recompensa = sin flecha, no se pulsa. */
  .pasos { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; justify-content: center; gap: 10px; }
  .paso-li { display: block; }
  .paso {
    --aug-tl: 7px; --aug-tr: 7px; --aug-bl: 7px; --aug-br: 7px; --aug-border-all: 1px;
    --acento: 194,205,214;
    display: grid; grid-template-columns: 52px 1fr; align-items: center; gap: 14px;
    padding: 11px 15px; text-decoration: none; color: inherit;
    --aug-border-bg: rgba(var(--acento), 0.16);
    background: linear-gradient(180deg, rgba(32,44,62,0.5), rgba(9,13,20,0.5));
  }
  a.paso { transition: background 0.18s ease, transform 0.18s ease; }
  a.paso:hover { background: linear-gradient(180deg, rgba(var(--acento), 0.2), rgba(9,13,20,0.5)); }
  a.paso:hover .paso__flecha { transform: translateX(3px); }
  a.paso:focus-visible { outline: 2px solid rgb(var(--acento)); outline-offset: 2px; }

  .paso--hecho { --acento: 95,208,224; --aug-border-bg: rgba(95,208,224,0.42); background: linear-gradient(180deg, rgba(63,169,201,0.14), rgba(9,13,20,0.5)); }
  .paso--toca { --acento: 232,169,63; --aug-border-bg: rgba(232,169,63,0.7); background: linear-gradient(180deg, rgba(232,169,63,0.18), rgba(9,13,20,0.5)); }
  .paso--premio { --acento: 138,154,170; }

  .paso__nodo { position: relative; width: 52px; height: 52px; display: grid; place-items: center; }
  .paso__im { width: 48px; height: 48px; object-fit: contain; filter: grayscale(1) brightness(0.5); opacity: 0.5; }
  .paso--hecho .paso__im, .paso--toca .paso__im { filter: none; opacity: 1; }
  .paso__mk { position: absolute; right: -2px; bottom: -2px; width: 17px; height: 17px; padding: 2px; border-radius: 50%; background: var(--night-1, #0b111b); color: var(--cyan); }

  .paso__d { min-width: 0; display: flex; flex-direction: column; gap: 3px; }
  .paso__cab { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; }
  .paso__n { font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mist); }
  .paso--hecho .paso__n { color: var(--cyan); }
  .paso--toca .paso__n { color: var(--amber); }
  .paso__pf { flex: none; font-size: 0.72rem; letter-spacing: 0.04em; color: var(--mist); }
  .paso--toca .paso__pf { color: var(--amber); }
  .paso__q { font-size: 0.86rem; line-height: 1.35; color: var(--moon); }
  .paso--hecho .paso__q, .paso--toca .paso__q { color: var(--bone); }

  /* La flecha: la señal de que ES una puerta. Solo en los pasos que se pulsan. */
  .paso__ir { display: inline-flex; align-items: center; gap: 6px; margin-top: 2px; font-size: 0.76rem; font-weight: 600; color: rgb(var(--acento)); }
  .paso__flecha { width: 15px; height: 15px; flex: none; transition: transform 0.18s ease; }

  /* La recompensa: insignia + habilidad, y la nota de que llega sola (sin flecha). */
  .paso__rec { font-size: 0.82rem; line-height: 1.4; color: var(--mist); }
  .paso__rec b { color: var(--moon); font-weight: 600; }
  .paso__nota { margin-top: 2px; font-size: 0.68rem; font-style: italic; color: rgba(194,205,214,0.5); }

  /* La que toca late (un solo halo, y significa). */
  .paso-li:has(.paso--toca) { position: relative; }
  .paso-li:has(.paso--toca)::after {
    content: ''; position: absolute; inset: -7px; z-index: -1; pointer-events: none;
    background: radial-gradient(closest-side, rgba(232,169,63,0.3), transparent);
    filter: blur(9px); opacity: 0.55;
  }
  @media (prefers-reduced-motion: no-preference) {
    .paso-li:has(.paso--toca)::after { animation: late 3.2s ease-in-out infinite alternate; }
    @keyframes late { from { opacity: 0.3; } to { opacity: 0.85; } }
  }

  /* ---- 2. TU AVANCE ---- */
  .m-ficha { grid-column: span 12; }
  .m-ficha__c { display: flex; align-items: center; gap: clamp(20px, 2.6vw, 46px); }
  .m-ficha__av {
    flex: none; width: auto; height: clamp(180px, 18vw, 270px);
    object-fit: contain; object-position: center bottom;
    filter: drop-shadow(0 18px 30px rgba(0,0,0,0.75));
  }
  /* El progreso crece para llenar; la barra se limita para seguir leyéndose como barra. */
  .m-ficha__prog { flex: 1 1 auto; min-width: 0; }
  .m-ficha__r { margin: 0; font-size: clamp(1.15rem, 1.6vw, 1.5rem); }
  .m-ficha__sub { margin: 0.5rem 0 0.7rem; font-size: 0.78rem; color: var(--mist); }
  .m-ficha__prog .barra { max-width: 460px; margin: 0 0 9px; }
