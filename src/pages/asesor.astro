---
// El asesor (P8). La Player Page del sistema: donde ves quien eres dentro del universo.
// Cuelga del avatar del HUD, no del menu de espacios: no es un sitio de la fortaleza.
//
// Una sola pantalla CON PESTANAS y sin scroll largo, como manda el sistema. Arriba quien
// eres (no cambia al cambiar de pestana); debajo lo que coleccionas.
//
// Lo que falta va EN SILUETA, no escondido: ver el hueco es lo que dice que hay camino.
import Fortaleza from '../layouts/Fortaleza.astro';
import { asesora, intervenciones, pasosDe, tieneInsignia, logrosGlobales, arquetipos, PF, NOMBRES_INSIGNIA } from '../data/demo.js';

const A = '/assets/emblemas-insignias/ui';

const arquetipo = arquetipos.find((a) => a.tuyo);
if (!arquetipo) throw new Error('El asesor pide el arquetipo del Test de Player y ninguno esta marcado como tuyo en demo.js.');

// LAS 36, en filas de tres: cada fila es SU intervencion, con sus tres pasos (Progresion,
// Reto de Torre, Evolucion). Agrupadas y no en una rejilla suelta porque las tres cuentan
// la misma historia: recorri, ejecute, selle. Lo ganado se DERIVA del estado con pasosDe(),
// no se escribe a mano. El nombre del sello es intervencion.insignia (el que usa la Torre);
// los de Progresion y Reto salen de NOMBRES_INSIGNIA.
const TIPOS = [
  { paso: 'progresion', nombre: 'Progresión',   dir: 'progresion', suf: 'progresion', pf: PF.progresion },
  { paso: 'reto',       nombre: 'Reto de Torre', dir: 'accion',    suf: 'accion',     pf: PF.reto },
  { paso: 'evolucion',  nombre: 'Evolución',    dir: 'sellos',    suf: 'sello',      pf: PF.evolucion },
];
const filas = intervenciones.map((i) => {
  const ganados = pasosDe(i);
  const nombres = { progresion: NOMBRES_INSIGNIA[i.n].progresion, reto: NOMBRES_INSIGNIA[i.n].reto, evolucion: i.insignia };
  return {
    ...i,
    piezas: TIPOS.map((t) => ({
      tier: t.nombre,
      insignia: nombres[t.paso],
      pf: t.pf,
      img: `${A}/insignias-intervencion/${t.dir}/insignia-i${String(i.n).padStart(2, '0')}-${t.suf}.webp`,
      ganada: ganados.includes(t.paso),
    })),
  };
});

const insigniasGanadas = filas.reduce((n, f) => n + f.piezas.filter((p) => p.ganada).length, 0);
const habilidadesGanadas = intervenciones.filter(tieneInsignia);
const hitosGanados = logrosGlobales.filter((l) => l.ganado).length;

const F_AZULEJO = 'tl-clip br-clip border';
const F_RANURA = 'tl-clip tr-clip bl-clip br-clip border';

const pestanas = [
  { id: 'insignias', nombre: 'Insignias', n: `${insigniasGanadas}/36` },
  { id: 'habilidades', nombre: 'Habilidades', n: `${habilidadesGanadas.length}/${intervenciones.length}` },
  { id: 'hitos', nombre: 'Hitos del ciclo', n: `${hitosGanados}/${logrosGlobales.length}` },
];
---

<Fortaleza title="El asesor, Club de la Asesoría" activa="/asesor">
  <!-- QUIEN ERES. No va en placa: eres tu, no un objeto clavado en la fortaleza.
       Vive fuera de las pestanas porque no cambia al cambiar de pestana. -->
  <header class="yo">
    <span class="figura yo__fig">
      <img src={asesora.avatar} alt={`Tu avatar como ${asesora.rango}`} width="433" height="580" data-yo-cara />
    </span>

    <div class="yo__d">
      <h1 class="display yo__r" data-yo-rango>{asesora.rango}</h1>
      <p class="yo__sub"><span data-yo-fort>{asesora.fortalecidas}</span> de {asesora.totalIntervenciones} intervenciones fortalecidas</p>

      <div class="barra" aria-hidden="true">
        {intervenciones.map((i) => (
          <span class={i.estado === 'fortalecida' ? 'is-on' : i.estado === 'activa' ? 'is-toca' : ''}></span>
        ))}
      </div>
      <p class="yo__falta">
        Te faltan <b data-yo-faltan>{asesora.faltanParaSiguiente}</b> para <span data-yo-rango-sig>{asesora.rangoSiguiente}</span>.
        El rango no sube por puntos: sube por intervenciones fortalecidas.
      </p>

      <!-- El arquetipo: quien eres cuando actuas. No es coleccion, es identidad, asi que
           vive aqui arriba y no en una pestana. -->
      <div class="arq" data-augmented-ui={F_RANURA}>
        <img class="arq__im" src={`${A}/arquetipos/arquetipo-${arquetipo.slug}.webp`} alt="" aria-hidden="true" width="256" height="256" />
        <div class="arq__d">
          <b class="arq__n">{arquetipo.nombre}</b>
          <span class="arq__l">{arquetipo.linea}</span>
        </div>
        <span class="arq__otros">
          {arquetipos.filter((a) => !a.tuyo).map((a) => (
            <img src={`${A}/arquetipos/arquetipo-${a.slug}.webp`} alt="" width="256" height="256" loading="lazy" />
          ))}
          <span class="pista pista--baja" role="tooltip" data-augmented-ui="tl-clip br-clip border">
            Los otros tres arquetipos del Test de Player. El tuyo es {arquetipo.nombre}.
          </span>
        </span>
      </div>
    </div>
  </header>

  <!-- LO QUE COLECCIONAS -->
  <section class="col" aria-label="Tu colección">
    <div class="tabs" role="tablist" aria-label="Tu colección">
      {pestanas.map((p, n) => (
        <button
          class={`tab${n === 0 ? ' is-on' : ''}`}
          type="button" role="tab" id={`tab-${p.id}`}
          aria-controls={`panel-${p.id}`} aria-selected={n === 0 ? 'true' : 'false'}
          data-tab={p.id}
          data-augmented-ui={F_AZULEJO}
        >
          {p.nombre}<span class="tab__n">{p.n}</span>
        </button>
      ))}
    </div>

    <!-- INSIGNIAS: las 36, en doce filas de tres. Cada fila es una intervención con sus
         tres pasos (Progresión, Reto de Torre, Evolución). -->
    <div class="panel" id="panel-insignias" role="tabpanel" aria-labelledby="tab-insignias" data-panel="insignias">
      <p class="col__ayuda">Tres insignias por intervención: la Progresión al ver la clase, el Reto de Torre al aplicarlo y la Evolución al dejarla reparada. Treinta y seis en total.</p>
      <ol class="ins">
        {filas.map((f) => (
          <li class={`ins__f ins__f--${f.estado}`}>
            <span class="ins__n" aria-hidden="true">{f.n}</span>
            <span class="ins__t">{f.titulo}</span>
            <span class="ins__p">
              {f.piezas.map((p) => (
                <span class={`pieza${p.ganada ? ' is-ganada' : ''}`} tabindex="0">
                  <img src={p.img} alt="" aria-hidden="true" width="256" height="256" loading="lazy" />
                  <span class="sr-only">{p.tier}: {p.insignia}. {p.ganada ? 'Conseguida' : 'Pendiente'}</span>
                  <span class="pista" role="tooltip" data-augmented-ui="tl-clip br-clip border">
                    <b class="pista__t">{p.insignia}</b>
                    {p.tier} de <b>{f.titulo}</b>.
                    <i class="pista__pf">+{p.pf} PF</i>
                    {!p.ganada && <i class="pista__no">Aún no la tienes</i>}
                  </span>
                </span>
              ))}
            </span>
          </li>
        ))}
      </ol>
    </div>

    <!-- HABILIDADES: una por intervencion fortalecida. No se ganan sueltas: son lo que
         te llevas de haber cerrado la intervencion entera. -->
    <div class="panel" id="panel-habilidades" role="tabpanel" aria-labelledby="tab-habilidades" data-panel="habilidades" hidden>
      <p class="col__ayuda">Cada intervención reparada deja una capacidad nueva. No se ganan sueltas: son lo que te llevas de haber cerrado la intervención entera.</p>
      <ul class="habs">
        {intervenciones.map((i) => {
          const ganada = tieneInsignia(i);
          return (
            <li class={`hab${ganada ? ' is-ganada' : ''}`} tabindex="0">
              <img src={`${A}/habilidades/habilidad-${i.habilidad.slug}.webp`} alt="" aria-hidden="true" width="256" height="256" loading="lazy" />
              <b class="hab__n">{i.habilidad.nombre}</b>
              <span class="sr-only">{ganada ? 'Desbloqueada' : 'Pendiente'}</span>
              <span class="pista" role="tooltip" data-augmented-ui="tl-clip br-clip border">
                {ganada ? <>La ganaste al fortalecer <b>{i.titulo}</b>.</> : <>Se desbloquea al fortalecer <b>{i.titulo}</b>.</>}
              </span>
            </li>
          );
        })}
      </ul>
    </div>

    <!-- HITOS: los seis grandes del ciclo. Son los momentos que marcan el ciclo entero,
         asi que van en cartas, con su mensaje, y no en renglones. -->
    <div class="panel" id="panel-hitos" role="tabpanel" aria-labelledby="tab-hitos" data-panel="hitos" hidden>
      <p class="col__ayuda">Los seis momentos que marcan el ciclo. No se ganan reparando una grieta suelta: los cruza la fortaleza entera al avanzar.</p>
      <ul class="hitos-c">
        {logrosGlobales.map((l) => (
          <li class={`hito-c${l.ganado ? ' is-ganado' : ''}`} data-augmented-ui="tl-clip br-clip border">
            <span class="hito-c__medalla">
              <img src={`${A}/logros-generales/${l.slug}.webp`} alt="" aria-hidden="true" width="256" height="256" loading="lazy" />
            </span>
            <div class="hito-c__body">
              <b class="hito-c__n">{l.nombre}</b>
              <span class="hito-c__c">{l.comoSeGana}</span>
              <p class="hito-c__msg">{l.mensaje}</p>
              <div class="hito-c__pie">
                {l.ganado ? (
                  <span class="hito-c__estado is-si">
                    <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3.5 8.5l3 3 6-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Conseguido
                  </span>
                ) : (
                  <span class="hito-c__estado">Pendiente</span>
                )}
                <span class="hito-c__pf">+{l.pf} PF</span>
              </div>
            </div>
            <span class="sr-only">{l.ganado ? 'Conseguido' : 'Pendiente'}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Fortaleza>

<script>
  import { montarPestanas } from '../scripts/pestanas.js';
  import { estadoDemo } from '../scripts/demo-director.js';
  montarPestanas();

  // El conmutador de demo enciende la coleccion segun el rango. El build renderiza rango 3
  // (13/36); esto la vuelve a derivar del numero de fortalecidas (0..12) que elija la demo.
  // Insignia por intervencion: n<=F fortalecida (3 pasos), n=F+1 activa (solo Progresion),
  // el resto bloqueada. Habilidad: al fortalecer. Hitos: por umbral de fortalecidas.
  (() => {
    const F = estadoDemo().fortalecidas;

    document.querySelectorAll('.ins__f').forEach((fila, idx) => {
      const n = idx + 1;
      let estado, on;
      if (n <= F) { estado = 'fortalecida'; on = [true, true, true]; }
      else if (n === F + 1 && F < 12) { estado = 'activa'; on = [true, false, false]; }
      else { estado = 'bloqueada'; on = [false, false, false]; }
      fila.className = 'ins__f ins__f--' + estado;
      fila.querySelectorAll('.pieza').forEach((p, i) => p.classList.toggle('is-ganada', on[i]));
    });

    document.querySelectorAll('.hab').forEach((h, idx) => h.classList.toggle('is-ganada', idx + 1 <= F));

    // Umbral de fortalecidas de cada hito, en el orden del DOM (entrada, mapa, reparacion,
    // grieta, tramo, cierre).
    const UMBRAL = [0, 0, 1, 1, 3, 12];
    const OK = '<svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3.5 8.5l3 3 6-7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg> Conseguido';
    document.querySelectorAll('.hito-c').forEach((li, idx) => {
      const ganado = F >= UMBRAL[idx];
      li.classList.toggle('is-ganado', ganado);
      const pie = li.querySelector('.hito-c__estado');
      if (pie) { pie.className = 'hito-c__estado' + (ganado ? ' is-si' : ''); if (ganado) pie.innerHTML = OK; else pie.textContent = 'Pendiente'; }
    });

    const insG = F * 3 + (F < 12 ? 1 : 0);
    const hitG = UMBRAL.filter((u) => F >= u).length;
    const setTab = (id, v, tot) => { const t = document.querySelector(`[data-tab=${id}] .tab__n`); if (t) t.textContent = `${v}/${tot}`; };
    setTab('insignias', insG, 36);
    setTab('habilidades', F, 12);
    setTab('hitos', hitG, 6);

    // En rango maximo no queda nada por subir: la linea de "te faltan" sobra.
    if (F >= 12) document.querySelectorAll('.yo__falta').forEach((el) => { el.hidden = true; });
  })();
</script>

<style is:global>
  /* El layout reserva hasta 88px de aire abajo, que en las paginas que scrollean da
     respiro y aqui es hueco muerto: era el que hacia que la pagina se pasara 69px y
     apareciera barra por nada. Esta pantalla esta hecha para caber. */
  .contenido:has(.yo) { padding-bottom: clamp(18px, 2.5vh, 28px); }

  /* LA LLEGADA, igual que el resto de la casa */
  .entra .yo, .entra .col { animation: destape-asesor 0.5s ease-out both; }
  .entra .col { animation-delay: 0.14s; }
  @keyframes destape-asesor {
    from { opacity: 0; transform: translateY(12px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* QUIEN ERES */
  .yo { display: flex; align-items: center; gap: clamp(18px, 2.4vw, 38px); margin-bottom: clamp(14px, 2vh, 26px); }
  .yo__fig { flex: none; }
  /* Grande a proposito: la figura del rango es LA recompensa de subir, y esta es su
     pantalla. En el Patio va pequena porque alli compite con la intervencion del mes;
     aqui no compite con nada. */
  .yo__fig img {
    /* min(vw, vh) y no vw a secas: quien manda aqui es el ALTO. Con solo vw, un
       1366x768 sacaba la figura a 369px sobre una ventana de 768 y la pagina scrolleaba
       120px. Es el mismo arreglo que la Puerta. */
    display: block; width: auto; height: clamp(230px, min(26vw, 39vh), 360px);
    object-fit: contain; object-position: center bottom;
    filter: drop-shadow(0 18px 30px rgba(0,0,0,0.75));
  }
  .yo__d { min-width: 0; flex: 1; max-width: 62ch; }
  .yo__r { margin: 0; font-size: clamp(1.5rem, 2.4vw, 2.1rem); color: var(--bone); }
  .yo__sub { margin: 5px 0 12px; font-size: 0.82rem; color: var(--mist); }
  .yo__falta { margin: 10px 0 0; max-width: 52ch; font-size: 0.78rem; line-height: 1.5; color: var(--mist); }
  .yo__falta b { color: var(--aqua); }

  /* El arquetipo */
  .arq {
    --aug-tl: 8px; --aug-tr: 8px; --aug-bl: 8px; --aug-br: 8px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.24);
    margin-top: clamp(14px, 2vh, 22px);
    display: flex; align-items: center; gap: 15px;
    padding: 13px 16px; max-width: 62ch;
    background: linear-gradient(180deg, rgba(20,32,46,0.5), rgba(9,13,20,0.4));
  }
  .arq__im { width: clamp(56px, 5vw, 72px); height: auto; flex: none; object-fit: contain; }
  .arq__d { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .arq__n { font-size: 0.92rem; font-weight: 600; color: var(--bone); }
  .arq__l { font-size: 0.78rem; line-height: 1.45; color: var(--mist); }
  /* Los otros tres, apagados y pequenos: dicen que hay cuatro y que el tuyo es uno */
  .arq__otros { position: relative; margin-left: auto; flex: none; display: flex; gap: 3px; }
  .arq__otros img { width: 26px; height: 26px; object-fit: contain; filter: grayscale(1) brightness(0.5); opacity: 0.5; }

  /* LAS PESTANAS */
  .tabs { display: flex; gap: 6px; margin-bottom: clamp(16px, 2vh, 22px); flex-wrap: wrap; }
  .tab {
    --aug-tl: 7px; --aug-br: 7px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.22);
    display: flex; align-items: center; gap: 8px;
    padding: 10px 16px; border: 0;
    background: transparent; color: var(--moon);
    font-family: var(--sans); font-size: 0.78rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.09em;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .tab:hover { background: rgba(63,169,201,0.14); color: var(--bone); }
  .tab.is-on {
    --aug-border-bg: var(--cyan);
    color: var(--bone);
    background: linear-gradient(180deg, rgba(63,169,201,0.3), rgba(63,169,201,0.07));
  }
  .tab__n { font-size: 0.72rem; letter-spacing: 0.02em; color: var(--mist); }
  .tab.is-on .tab__n { color: var(--aqua); }

  .col__ayuda { margin: 0 0 14px; max-width: 70ch; font-size: 0.76rem; line-height: 1.5; color: var(--mist); }

  /* LA PARED DE INSIGNIAS: 36, en doce filas de tres. Las filas caen por COLUMNAS (6 filas,
     dos columnas): por filas bajaria 1,3,5 por la izquierda y son una secuencia; asi baja
     1-6 y luego 7-12. El titulo va a ancho FIJO (no 1fr) para que los tres medallones caigan
     siempre en el mismo sitio y las doce filas se lean de una pasada. */
  .ins {
    list-style: none; margin: 0; padding: 0;
    display: grid;
    grid-template-rows: repeat(6, auto);
    grid-auto-flow: column;
    gap: 3px clamp(20px, 3vw, 48px);
  }
  .ins__f {
    display: grid; grid-template-columns: 26px minmax(0, 30ch) auto; align-items: center; gap: 12px;
    padding: 5px 10px;
    border-left: 2px solid rgba(194,205,214,0.16);
  }
  /* Color por estado (canon): oro para lo fortalecido (trofeo), ambar para la del mes (la
     accion de ahora), mist para lo bloqueado. La barra de arriba es medidor de progreso y
     sigue en cian, que es otro lenguaje (hecho-en-lista, no trofeo). */
  .ins__f--fortalecida { border-left-color: var(--gold); }
  .ins__f--activa { border-left-color: var(--amber); background: rgba(232,169,63,0.08); }
  .ins__f--bloqueada { opacity: 0.55; }
  .ins__n { font-family: var(--display); font-size: 0.86rem; color: var(--mist); text-align: center; }
  .ins__f--fortalecida .ins__n { color: var(--gold); }
  .ins__f--activa .ins__n { color: var(--amber); }
  .ins__t { font-size: 0.78rem; color: var(--moon); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ins__p { display: flex; gap: 7px; }

  /* La pieza: la insignia. Ganada, arde. Pendiente, en SILUETA, que es lo que dice que
     hay camino: esconderla no contaria nada. */
  .pieza { position: relative; display: block; width: clamp(48px, 3.6vw, 56px); height: clamp(48px, 3.6vw, 56px); }
  .pieza img { width: 100%; height: 100%; object-fit: contain; transition: transform 0.18s ease; }
  .pieza:not(.is-ganada) img { filter: grayscale(1) brightness(0.42); opacity: 0.6; }
  .pieza.is-ganada img { filter: drop-shadow(0 2px 6px rgba(0,0,0,0.6)); }
  .pieza:hover img, .pieza:focus-visible img { transform: scale(1.12); }
  .pista__pf { display: block; margin-top: 3px; font-style: normal; font-size: 0.66rem; color: var(--amber); }
  .pista__no { display: block; margin-top: 3px; font-style: normal; font-size: 0.66rem; color: var(--mist); }
  /* La cabecera del tooltip (el nombre de la insignia) va en bloque; las negritas DENTRO de
     la frase (el titulo) van en linea, para que el punto no caiga solo en su renglon. */
  .pista__t { display: block; color: var(--bone); margin-bottom: 2px; }
  .pista b { color: var(--bone); }

  /* HABILIDADES */
  .habs { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(6, 1fr); gap: clamp(8px, 1vw, 16px); }
  .hab {
    position: relative; display: flex; flex-direction: column; align-items: center; gap: 8px;
    text-align: center; padding: 14px 8px 12px; border-radius: 10px;
    background: linear-gradient(180deg, rgba(194,205,214,0.03), transparent);
    box-shadow: inset 0 0 0 1px rgba(194,205,214,0.06);
    transition: transform 0.18s ease, box-shadow 0.2s ease, background 0.2s ease;
  }
  .hab.is-ganada {
    background: linear-gradient(180deg, rgba(63,169,201,0.07), rgba(63,169,201,0.01));
    box-shadow: inset 0 0 0 1px rgba(95,208,224,0.16);
  }
  .hab:hover, .hab:focus-visible { box-shadow: inset 0 0 0 1px rgba(95,208,224,0.3); outline: none; }
  .hab img { width: clamp(62px, 6vw, 84px); height: auto; object-fit: contain; transition: transform 0.18s ease; }
  .hab:not(.is-ganada) img { filter: grayscale(1) brightness(0.42); opacity: 0.6; }
  .hab.is-ganada img { filter: drop-shadow(0 3px 8px rgba(0,0,0,0.6)); }
  .hab:hover img, .hab:focus-visible img { transform: scale(1.08); }
  .hab__n { font-size: 0.7rem; line-height: 1.3; color: var(--mist); }
  .hab.is-ganada .hab__n { color: var(--bone); }

  /* HITOS DEL CICLO */
  /* Seis (CONTENIDO 4.3 B). En cartas horizontales, dos por fila: medalla a la izquierda,
     y a la derecha el nombre, como se gana, el mensaje y al pie el estado y el PF. El
     ganado arde en ambar; el pendiente queda en penumbra. Horizontal y no vertical para
     que las seis quepan sin scroll largo. */
  .hitos-c {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(10px, 1.4vw, 16px);
  }
  .hito-c {
    --aug-tl: 10px; --aug-br: 10px;
    --aug-border-all: 1px;
    --aug-border-bg: rgba(194,205,214,0.16);
    display: flex; align-items: flex-start; gap: clamp(11px, 1.3vw, 16px);
    padding: clamp(11px, 1.2vw, 15px) clamp(14px, 1.5vw, 19px);
    background: linear-gradient(180deg, rgba(20,32,46,0.5), rgba(9,13,20,0.34));
  }
  .hito-c.is-ganado {
