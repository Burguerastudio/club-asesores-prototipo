---
// Shell persistente de la plataforma: cabecera + fondo + tokens.
// Lo heredan todas las pantallas de dentro (el Login no, que va sin navegacion).
import '../styles/tokens.css';
import Velo from '../components/Velo.astro';
import { asesora, avisos, avisosSinLeer } from '../data/demo.js';

const { title = 'Club de la Asesoría', activa = '' } = Astro.props;

// La cabecera es un HUD: cada pieza es una ranura, con el mismo chaflan en diagonal
// que los azulejos de sala (ver docs/DESIGN.md). El filo solo se dibuja donde hay
// algo encendido o enmarcado; en las ranuras apagadas sobra.
const RANURA = 'tl-clip br-clip';

// El Patio es el Dashboard: el patio de armas del castro, donde caes al cruzar la Puerta
// (el Login) y de donde salen los caminos a cada sala. El Mapa es otra cosa: el viaje.
//
// El desplegable del avatar es el estandar del sistema Sepia: lo personal cuelga de
// tu cara, no del menu de espacios. "El asesor" (P8) es la Player Page de Club: rango,
// avatar, insignias, PF y los arquetipos. Y "Ajustes" y no "Mi cuenta", que se
// confundia con el perfil (el estandar tambien lo llama Ajustes).
//
// Dos desviaciones del estandar, las dos del 2026-07-17 y las dos en docs/DESIGN.md:
//   1. Recompensas es el Shop, y en el estandar el Shop vive a la izquierda. Aqui cuelga
//      del avatar porque en La Fortaleza lo que reclamas con tus PF es tuyo, no un sitio
//      del castro.
//   2. NO hay Calendario, y el estandar lo pone aqui. Club no tiene directos, ni talleres,
//      ni sesiones (reunion de equipo), asi que la pagina se quedaba sin contenido.
const menuJugador = [
  { href: '/asesor', label: 'El asesor' },
  { href: '/recompensas', label: 'Recompensas' },
  { href: '/ajustes', label: 'Ajustes' },
];

const nav = [
  { href: '/dashboard', label: 'El Patio' },
  { href: '/mapa', label: 'Mapa' },
  { href: '/sala-mandos', label: 'Sala de Mandos' },
  { href: '/biblioteca', label: 'Biblioteca' },
  { href: '/consejo', label: 'El Consejo' },
  { href: '/mirador', label: 'Mirador' },
  { href: '/torre-retos', label: 'Torre de Retos' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <!-- La cara del enlace cuando se comparte (los gates van por URL de Vercel) -->
    <meta name="theme-color" content="#090D14" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="La Fortaleza del Asesor, Club de la Asesoría" />
    <meta property="og:description" content="Tu despacho es una fortaleza. Nara ya ha encontrado la primera grieta." />
    <meta property="og:image" content="https://club-asesores-prototipo.vercel.app/og.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- Antes de pintar nada: si hay movimiento permitido, la pagina llega con el velo
         echado (.entra) y las animaciones de llegada lo van descubriendo. En el <head>
         y no en el <body> para que ningun frame se cuele antes que la clase. -->
    <script is:inline>
      if (matchMedia('(prefers-reduced-motion: no-preference)').matches) document.documentElement.classList.add('entra');
    </script>
  </head>
  <body>
    <a class="saltar" href="#contenido" data-augmented-ui="tl-clip br-clip">Saltar al contenido</a>

    <!-- Toda navegacion de la casa cruza por aqui: es lo que cose el prototipo -->
    <Velo />

    <!-- El <i> lleva la niebla: la vineta del ::after tiene que pintarse encima de todo,
         y un pseudo no puede quedar sobre el otro si ambos cuelgan del mismo elemento. -->
    <div class="fondo" aria-hidden="true"><i></i></div>

    <header class="shell">
      <div class="shell__in">
        <nav class="shell__nav" aria-label="Espacios de la fortaleza">
          {nav.map((n) => (
            <a
              href={n.href}
              class={activa === n.href ? 'is-activa' : ''}
              data-augmented-ui={activa === n.href ? `${RANURA} border` : RANURA}
              aria-current={activa === n.href ? 'page' : undefined}
            >{n.label}</a>
          ))}
        </nav>

        <div class="shell__yo">
          <!-- Campana y lupa son herramientas, y van ANTES del contador. Entre el contador
               y el avatar no se mete nada: esos dos son el asesor (lo que tiene y quien es)
               y no se separan. Ver docs/DESIGN.md.
               La pildora y la bandeja van FUERA del boton, en su caja: augmented-ui recorta
               la forma del boton y dentro las encerraria. Misma trampa que las motas. -->

          <!-- La campana SI abre su bandeja, como en UpGrade: el punto promete avisos, y un
               punto que no los enseña miente. Los avisos son estado de la demo (demo.js),
               como los PF; lo que vive en el plugin es de donde salen de verdad. -->
          <span class="util-caja">
            <button
              class="util"
              type="button"
              aria-haspopup="true"
              aria-expanded="false"
              aria-controls="bandeja"
              aria-label={`Avisos de la fortaleza, ${avisosSinLeer} sin leer`}
              data-augmented-ui={RANURA}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <!-- La campana del castro: hombros rectos y falda acampanada, del mismo
                     trazo labrado que el resto de la casa. -->
                <path d="M12 3.8v1.6" />
                <path d="M6.8 16.2v-5.6a5.2 5.2 0 0 1 10.4 0v5.6l2 2.6H4.8l2-2.6z" />
                <path d="M13.9 18.8a1.9 1.9 0 0 1-3.8 0" />
              </svg>
              {avisosSinLeer > 0 && <i class="util__punto" aria-hidden="true"></i>}
            </button>

            <div class="bandeja" id="bandeja" hidden data-augmented-ui="tl-clip br-clip border">
              <header class="bandeja__cab">
                <b>Avisos</b>
                <span>{avisosSinLeer} sin leer</span>
              </header>
              <ul class="bandeja__lista">
                {avisos.map((a) => (
                  <li class={a.nueva ? 'is-nueva' : ''}>
                    <span class="bandeja__mini" aria-hidden="true"><img src={a.img} alt="" loading="lazy" width="64" height="64" /></span>
                    <div>
                      <p>{a.texto}</p>
                      <time>{a.cuando}</time>
                    </div>
                  </li>
                ))}
              </ul>
              <!-- Marcar como leido lo resuelve el plugin: aqui no navega, avisa -->
              <button
                class="bandeja__todo"
                type="button"
                data-integracion="buddyboss:marcar-avisos-leidos"
                data-aviso="Los avisos se marcan solos cuando la fortaleza esté conectada."
              >
                Dar por leídos
                <!-- Esta pildora NO va --baja: colgaria por debajo de la bandeja, que
                     tambien va recortada con augmented-ui, y el recorte se la comia.
                     Hacia arriba se queda dentro, que es donde se ve. -->
                <span class="pista" role="tooltip" aria-live="polite" data-augmented-ui="tl-clip br-clip border">Dar por leídos</span>
              </button>
            </div>
          </span>

          <span class="util-caja">
            <button
              class="util"
              type="button"
              aria-label="Buscar en la fortaleza"
              data-integracion="buddyboss:busqueda"
              data-aviso="Desde aquí buscarás en toda la fortaleza. En el prototipo aún no."
              data-augmented-ui={RANURA}
            >
              <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <circle cx="10.8" cy="10.8" r="6.3" />
                <path d="M15.4 15.4l4.3 4.3" />
              </svg>
            </button>
            <span class="pista pista--baja" role="tooltip" aria-live="polite" data-augmented-ui="tl-clip br-clip border">Buscar</span>
          </span>

          <!-- La pildora del sistema, no el tooltip gris del navegador. Va en la caja y
               no dentro de .pf por lo mismo que la de los botones: el recorte de
               augmented-ui la encerraba, y por eso no se habia visto nunca. Y cuelga
               hacia abajo, que en el HUD por encima solo esta el borde de la ventana. -->
          <span class="pf-caja">
            <span class="pf" data-augmented-ui={`${RANURA} border`}>
              <img src="/assets/moneda/ui/pf.webp" alt="" aria-hidden="true" width="270" height="512" />
              {asesora.pf.toLocaleString('es-ES')}
              <span class="sr-only">Puntos de Fortaleza</span>
            </span>
            <span class="pista pista--baja" role="tooltip" data-augmented-ui="tl-clip br-clip border">Puntos de Fortaleza</span>
          </span>

          <!-- Lo tuyo cuelga de tu avatar: tu ficha, tus recompensas, tus fechas y tus ajustes.
               No son espacios de la fortaleza, asi que no van en el menu de la izquierda. -->
          <div class="jugador">
            <button class="chip" type="button" aria-haspopup="true" aria-expanded="false" aria-controls="menu-jugador">
              <span class="chip__marco" data-augmented-ui={`${RANURA} border`}>
                <img class="chip__av" src={asesora.retrato} alt="" aria-hidden="true" width="512" height="512" />
              </span>
              <span class="chip__txt"><b>{asesora.nombre}</b><i>{asesora.rango}</i></span>
              <svg class="chip__flecha" viewBox="0 0 10 6" aria-hidden="true" focusable="false">
                <path d="M1 1l4 4 4-4" />
              </svg>
            </button>

            <div class="menu" id="menu-jugador" hidden data-augmented-ui="tl-clip br-clip border">
              {menuJugador.map((m) => (
                <a href={m.href} class={activa === m.href ? 'is-activa' : ''} aria-current={activa === m.href ? 'page' : undefined}>{m.label}</a>
              ))}
              <!-- Salir es de otra clase que lo demas: no te lleva a un sitio de la
                   fortaleza, te saca. Va detras de un filo para que no se pulse de paso. -->
              <a class="menu__salir" href="/">Cerrar sesión</a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <main class="contenido" id="contenido" tabindex="-1"><slot /></main>

    <script>
      import { montarCursor } from '../scripts/cursor.js';
      import { montarVelo } from '../scripts/velo.js';
      import { montarIntegracion } from '../scripts/integracion.js';
      import { cablearInterfaz, arrancarMusica } from '../scripts/audio.js';

      montarCursor();
      montarVelo();
      montarIntegracion();
      // El sonido sigue montado igual: cablearInterfaz() escucha sobre el document, asi
      // que cada pantalla nueva nace sonando. Lo que ya no vive aqui es el MANDO: el
      // interruptor y los dos volumenes van en Ajustes (P12). Ver docs/DESIGN.md.
      cablearInterfaz();

      // Dentro de la fortaleza la musica ya viene queriendose (se pulso Entrar en el Login).
      // Si el navegador la bloquea, arrancarMusica la deja armada para el primer gesto.
      // Diferida a la carga completa: su descarga (1.9MB) competia con el primer render,
      // y el fundido de 1.6s disimula la entrada tardia.
      if (document.readyState === 'complete') setTimeout(arrancarMusica, 250);
      else addEventListener('load', () => setTimeout(arrancarMusica, 250), { once: true });

      // Los dos desplegables del HUD (la bandeja de avisos y el menu del jugador) se
      // comportan igual, asi que el comportamiento se escribe una vez.
      //
      // Sin stopPropagation a proposito: cortaba el evento antes de llegar al document,
      // y entonces abrir uno no cerraba el otro (se quedaban los dos abiertos). En vez de
      // cortar, el cierre de fuera ignora los clics sobre el propio boton.
      const desplegable = (boton: HTMLElement | null, panel: HTMLElement | null) => {
        if (!boton || !panel) return;
        const abrir = (si: boolean) => {
          panel.hidden = !si;
          boton.setAttribute('aria-expanded', String(si));
        };
        boton.addEventListener('click', () => abrir(panel.hidden === true));

        document.addEventListener('click', (e) => {
          if (panel.hidden) return;
          const donde = e.target as Node;
          if (panel.contains(donde) || boton.contains(donde)) return;
          abrir(false);
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && !panel.hidden) { abrir(false); boton.focus(); }
        });
        // Al tabular mas alla del ultimo enlace se quedaba abierto sobre el contenido
        const caja = boton.parentElement;
        caja?.addEventListener('focusout', (e) => {
          if (!caja.contains((e as FocusEvent).relatedTarget as Node)) abrir(false);
        });
      };

      desplegable(document.querySelector('.jugador .chip'), document.querySelector('.menu'));
      desplegable(document.querySelector('.util[aria-controls="bandeja"]'), document.querySelector('.bandeja'));
    </script>

    <style is:global>
      /* Fondo: piedra fria y niebla, sin escena. El panel manda, pero el fondo TRABAJA:
         antes las capas estaban bajo el umbral perceptible y el Patio leia plano al lado
         del Login. Piedra al 9, niebla al 14, luz alta mas ancha, y una vineta encima
         de todo que oscurece los bordes para que el ojo caiga en la placa mayor. */
      .fondo { position: fixed; inset: 0; z-index: -1; background:
        radial-gradient(ellipse 85% 55% at 50% 0%, rgba(63,169,201,0.11), transparent 64%),
        linear-gradient(180deg, #0B1220, #090D14 58%, #0C1019); }
      .fondo::before { content: ''; position: absolute; inset: 0;
        background-image: url('/assets/texturas/ui/textura-piedra.webp'); background-size: 640px;
        opacity: 0.09; mix-blend-mode: soft-light; }
      .fondo i { position: absolute; inset: 0;
        background-image: url('/assets/texturas/ui/textura-niebla.webp'); background-size: cover; background-position: center;
        opacity: 0.14; mix-blend-mode: screen; }
      .fondo::after { content: ''; position: absolute; inset: 0;
        background: radial-gradient(ellipse at 50% 32%, transparent 55%, rgba(4, 7, 12, 0.5) 100%); }

      /* HUD, no barra: las piezas flotan sobre la fortaleza y no hay franja ni canto.
         En vez de fondo, un velo que se desvanece: el contenido pasa por debajo y se
         apaga solo, sin cortar contra un borde. Que no haya linea es lo que lo integra. */
      .shell {
        position: sticky; top: 0; z-index: 50;
        padding-bottom: 26px;
        background: linear-gradient(to bottom,
          rgba(9,13,20,0.95) 0%, rgba(9,13,20,0.86) 42%,
          rgba(9,13,20,0.5) 74%, rgba(9,13,20,0) 100%);
      }
      /* En % y no en vw: vw cuenta la barra de scroll y la cabecera se desalineaba
         del contenido por unos 7px. */
      .shell__in { width: min(1400px, 94%); margin: 0 auto; height: var(--alto-shell); display: flex; align-items: center; gap: clamp(14px, 2.6vw, 38px); }
      /* Menu de juego: los espacios son ranuras que se encienden, no enlaces subrayados.
         Sin logo delante: dentro de la fortaleza ya sabes donde estas, y el HUD de un
         juego no lleva la marca. Asi el menu manda desde el primer pixel. */
      .shell__nav { display: flex; gap: clamp(2px, 0.4vw, 6px); margin-right: auto; min-width: 0; overflow-x: auto; scrollbar-width: none; }
      .shell__nav::-webkit-scrollbar { display: none; }
      .shell__nav a {
        --aug-tl: 7px; --aug-br: 7px;
        --aug-border-all: 1px;
        --aug-border-bg: rgba(63,169,201,0.6);
        flex: none; padding: 11px clamp(10px, 1.05vw, 18px);
        font-size: 0.8rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.085em;
        color: var(--moon); text-decoration: none; white-space: nowrap;
        background: transparent;
        transition: background 0.2s ease, color 0.2s ease;
      }
      .shell__nav a:hover { background: rgba(63,169,201,0.14); color: var(--bone); }
      .shell__nav a:active, .menu a:active { background: rgba(63,169,201,0.24); }
      /* La sala en la que estas: ranura encendida */
      .shell__nav a.is-activa {
        color: var(--bone);
        background: linear-gradient(180deg, rgba(63,169,201,0.3), rgba(63,169,201,0.07));
      }

      /* Zona del jugador, arriba a la derecha, en este orden: campana, lupa, cumulo de
         PF y ficha. Las herramientas van antes; el contador y el avatar cierran juntos
         porque los dos son el asesor (lo que tiene y quien es). Ver docs/DESIGN.md. */
      .shell__yo { flex: none; display: flex; align-items: center; gap: clamp(10px, 1.2vw, 16px); }

      /* La caja ancla la pildora, que tiene que quedar FUERA del elemento recortado:
         augmented-ui recorta con clip-path y encierra a todo hijo que asome (la misma
         razon por la que las motas viven en .placa-caja). Ver docs/DESIGN.md. */
      .util-caja, .pf-caja { position: relative; flex: none; display: flex; }
      /* Al tabular, la pildora la enciende el foco del boton, que ya no es su padre */
      .util:focus-visible ~ .pista { opacity: 1; visibility: visible; }

      /* Campana y lupa: mismo boton-ranura que el resto del HUD. Geometria calcada del
         .sonido que vivia aqui (y que sigue en el Login), para no abrir un molde nuevo. */
      .util {
        --aug-tl: 6px; --aug-br: 6px;
        flex: none; display: grid; place-items: center; width: 34px; height: 34px;
        padding: 0; border: 0; background: transparent; color: var(--mist);
        transition: color 0.2s ease, background 0.2s ease;
      }
      .util:hover { color: var(--bone); background: rgba(63, 169, 201, 0.13); }
      .util:active { background: rgba(63, 169, 201, 0.24); }
      .util[aria-expanded='true'] { color: var(--aqua); background: rgba(63, 169, 201, 0.18); }
      .util svg {
        width: 19px; height: 19px;
        fill: none; stroke: currentColor; stroke-width: 1.6; stroke-linecap: round; stroke-linejoin: round;
      }

      /* Avisos sin leer. En cian y no en ambar: el ambar es la accion principal de la
         pantalla y ya lo gasta el CTA del Patio; dos ambares matan la jerarquia. El cian
         de la casa es justo el que dice "esto esta vivo". Va dentro del boton, lejos de
         las esquinas chaflanadas (tl y br), asi que el recorte no lo toca. */
      .util__punto {
        position: absolute; top: 5px; right: 6px;
        width: 6px; height: 6px; border-radius: 50%;
        background: var(--aqua);
        box-shadow: 0 0 6px rgba(95, 208, 224, 0.9);
      }

      /* La bandeja: misma placa pequena que el menu del jugador, mismo material */
      .bandeja {
        position: absolute; top: calc(100% + 10px); right: 0; z-index: 60;
        --aug-tl: 10px; --aug-br: 10px;
        --aug-border-all: 1px;
        --aug-border-bg: linear-gradient(150deg, rgba(194,205,214,0.5), rgba(63,169,201,0.22) 40%, rgba(58,70,84,0.36));
        width: min(374px, calc(100vw - 40px));
        background-color: rgba(9,13,20,0.97);
        background-image: var(--grano);
        filter: drop-shadow(0 18px 34px rgba(0,0,0,0.9));
      }
      .bandeja[hidden] { display: none; opacity: 0; translate: 0 -6px; }
      .bandeja {
        opacity: 1; translate: 0 0;
        transition: opacity 0.18s ease, translate 0.18s ease, display 0.18s allow-discrete;
      }
      @starting-style { .bandeja { opacity: 0; translate: 0 -6px; } }

      .bandeja__cab { display: flex; align-items: baseline; justify-content: space-between; padding: 13px 16px 10px; }
      .bandeja__cab b { font-family: var(--display); font-weight: 600; font-size: 0.92rem; color: var(--bone); letter-spacing: 0.03em; }
      .bandeja__cab span { font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--aqua); }

      .bandeja__lista { list-style: none; margin: 0; padding: 0 8px; }
      .bandeja__lista li { position: relative; display: flex; gap: 11px; align-items: flex-start; padding: 11px 9px; }
      .bandeja__lista li + li { border-top: 1px solid rgba(194,205,214,0.1); }
      .bandeja__lista p { margin: 0; font-size: 0.78rem; line-height: 1.42; color: var(--moon); }
      .bandeja__lista time { display: block; margin-top: 4px; font-size: 0.68rem; color: var(--mist); }
      .bandeja__mini { flex: none; width: 32px; height: 32px; }
      .bandeja__mini img { width: 100%; height: 100%; object-fit: contain; }
      /* Lo no leido lleva el filo cian; lo leido se apaga. Nada de puntos ni negritas:
         el estado se ve en la materia, como en el resto de la casa. */
      .bandeja__lista li.is-nueva::before {
        content: ''; position: absolute; left: 0; top: 11px; bottom: 11px; width: 2px;
        background: var(--aqua);
      }
      .bandeja__lista li:not(.is-nueva) { opacity: 0.55; }

      .bandeja__todo {
        position: relative; /* ancla de su pildora */
        display: block; width: calc(100% - 16px); margin: 6px 8px 9px; padding: 10px;
        border: 0; border-top: 1px solid rgba(194,205,214,0.14);
        background: transparent; color: var(--mist);
        font-family: var(--sans); font-size: 0.7rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: 0.11em;
        transition: color 0.2s ease, background 0.2s ease;
      }
      .bandeja__todo:hover { color: var(--bone); background: rgba(63,169,201,0.1); }
      /* Aqui la pildora es SOLO para el aviso: el boton ya dice lo que hace, y repetirlo
         al pasar por encima es ruido. Solo habla cuando se pulsa. */
      .bandeja__todo:hover > .pista { opacity: 0; visibility: hidden; }
      .bandeja__todo > .pista.is-dicha { opacity: 1; visibility: visible; }

      /* Los PF son un contador de recurso: va en su ranura, como en cualquier HUD */
      .pf {
        /* El ancla de la pildora es .pf-caja, no esto: aqui dentro la recorta augmented-ui */
        --aug-tl: 6px; --aug-br: 6px;
        --aug-border-all: 1px;
        --aug-border-bg: rgba(63,169,201,0.34);
        display: inline-flex; align-items: center; gap: 8px;
        padding: 6px 13px 6px 9px;
        background: linear-gradient(180deg, rgba(63,169,201,0.13), rgba(9,13,20,0.4));
        font-size: 0.92rem; font-weight: 600; color: var(--aqua); letter-spacing: 0.02em;
      }
      .pf img { width: 20px; height: 20px; object-fit: contain; }

      /* Ficha de personaje: el retrato va enmarcado y chaflanado, no en circulo.
         El circulo dentro de una pildora es lo mas de web que hay. */
      .jugador { position: relative; }
      .chip { display: flex; align-items: center; gap: 11px; text-decoration: none; padding: 0; border: 0; background: transparent; }
      .chip__flecha { width: 9px; height: 6px; flex: none; fill: none; stroke: var(--mist); stroke-width: 1.5; stroke-linecap: round; stroke-linejoin: round; transition: transform 0.22s ease, stroke 0.2s ease; }
      .chip:hover .chip__flecha { stroke: var(--bone); }
      .chip[aria-expanded='true'] .chip__flecha { transform: rotate(180deg); stroke: var(--aqua); }

      /* El desplegable: una placa pequena, mismo material que las del Patio */
      .menu {
        position: absolute; top: calc(100% + 10px); right: 0; z-index: 60;
        --aug-tl: 10px; --aug-br: 10px;
        --aug-border-all: 1px;
        --aug-border-bg: linear-gradient(150deg, rgba(194,205,214,0.5), rgba(63,169,201,0.22) 40%, rgba(58,70,84,0.36));
        min-width: 190px; padding: 7px;
        display: flex; flex-direction: column;
        background-color: rgba(9,13,20,0.97);
        background-image: var(--grano);
        filter: drop-shadow(0 18px 34px rgba(0,0,0,0.9));
      }
      .menu[hidden] { display: none; opacity: 0; translate: 0 -6px; }
      .menu {
        opacity: 1; translate: 0 0;
        transition: opacity 0.18s ease, translate 0.18s ease, display 0.18s allow-discrete;
      }
      @starting-style { .menu { opacity: 0; translate: 0 -6px; } }
      .menu a {
        --aug-tl: 5px; --aug-br: 5px;
        padding: 10px 13px; font-size: 0.78rem; color: var(--moon); text-decoration: none; white-space: nowrap;
        transition: background 0.18s ease, color 0.18s ease;
      }
      .menu a:hover { background: rgba(63,169,201,0.14); color: var(--bone); }
      .menu a.is-activa { color: var(--bone); background: linear-gradient(180deg, rgba(63,169,201,0.26), rgba(63,169,201,0.06)); }
      /* Salir no es un destino mas: se separa con un filo y se queda en gris.
         No lleva cian: el cian de la casa dice "esto esta vivo", y esto apaga. */
      .menu .menu__salir { margin-top: 5px; padding-top: 12px; border-top: 1px solid rgba(194,205,214,0.16); color: var(--mist); }
      .menu .menu__salir:hover { background: rgba(194,205,214,0.1); color: var(--bone); }
      .chip__marco {
        --aug-tl: 6px; --aug-br: 6px;
        --aug-border-all: 1px;
        --aug-border-bg: var(--linea-fuerte);
        display: block; flex: none; padding: 2px; background: var(--night-2);
        transition: none;
      }
      .chip:hover .chip__marco { --aug-border-bg: var(--cyan); }
      .chip__av { display: block; width: 34px; height: 34px; object-fit: cover; background: var(--night-2); }
      .chip__txt { display: flex; flex-direction: column; line-height: 1.2; }
      .chip__txt b { font-size: 0.78rem; font-weight: 600; color: var(--bone); transition: color 0.2s ease; }
      .chip__txt i { font-size: 0.7rem; font-style: normal; color: var(--mist); }
      .chip:hover .chip__txt b { color: var(--aqua); }

      /* Recorta a lo ancho de la pagina, no del contenedor: lo que se sale a proposito
         (las motas del filo, el Rebelde) puede volar por el margen lateral y solo se
         recorta en el borde del viewport, donde ya no se ve, y sin generar scroll.
         Con margen de recorte sobre el contenedor no vale: por debajo de 1489px el
         margen lateral es menor que el de recorte y la zona pintada se sale de la pagina.
         Y clip en los dos ejes, no solo en x: con clip en uno y visible en el otro, el
         visible computa a hidden, lo vuelve contenedor de scroll y ahi el recorte
         se aplica a hueso (era lo que le cortaba la mano al Rebelde). */
      .contenido {
        overflow: clip;
        padding: clamp(14px, 2.5vh, 28px) 0 clamp(48px, 8vh, 88px);
      }
      /* El ancho de lectura lo ponen los hijos, ya que el padre va a toda la pagina */
      .contenido > * { width: min(1400px, 94%); margin-inline: auto; }

      /* Con la septima entrada (El Patio) el menu ya no cabe entero por debajo de 1100:
         se aprieta el cuerpo y el tracking antes que dejar que se corte. */
      @media (max-width: 1100px) {
        .shell__nav a { padding: 11px 8px; font-size: 0.74rem; letter-spacing: 0.05em; }
      }
      @media (max-width: 980px) {
        .shell__in { gap: 12px; }
        .chip__txt { display: none; }
      }
    </style>
  </body>
</html>
